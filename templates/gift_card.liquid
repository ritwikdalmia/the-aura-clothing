<script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>
{{ 'template-giftcard.css' | asset_url | stylesheet_tag }}

{%- assign formatted_balance = gift_card.balance | money_without_trailing_zeros | strip_html -%}

<div class="gift-card-page-wrapper">
  <!-- Background Decorative Elements -->
  <div class="gift-card__decorations no-print">
    <div class="decor-item item-1"><img src="{{ 'icon-shirt.svg' | asset_url }}" alt="" loading="lazy"></div>
    <div class="decor-item item-2"><img src="{{ 'icon-pants.svg' | asset_url }}" alt="" loading="lazy"></div>
    <div class="decor-item item-3"><img src="{{ 'icon-box.svg' | asset_url }}" alt="" loading="lazy"></div>
    <div class="decor-item item-4"><img src="{{ 'icon-heart.svg' | asset_url }}" alt="" loading="lazy"></div>
    <div class="decor-item item-5"><img src="{{ 'icon-shirt.svg' | asset_url }}" alt="" loading="lazy"></div>
    <div class="decor-item item-6"><img src="{{ 'icon-box.svg' | asset_url }}" alt="" loading="lazy"></div>
  </div>

  <div class="gift-card">
    <header class="gift-card__header">
      <div class="gift-card__header-content">
        <div class="header-logo-container">
          {%- if settings.logo != blank -%}
            {{ settings.logo | image_url: width: 140 | image_tag: class: 'header-logo', alt: shop.name }}
          {%- else -%}
            <span class="header-logo-text">{{ shop.name | slice: 0, 1 }}</span>
          {%- endif -%}
        </div>
        <div class="gift-card__balance-display">
          <h1>
            {% if settings.currency_code_enabled %}
              {{ gift_card.balance | money_with_currency }}
            {% else %}
              {{ gift_card.balance | money }}
            {% endif %}
          </h1>
          <p class="balance-label">{{ 'gift_cards.issued.subtext' | t }}</p>
        </div>
      </div>
      
      {%- if gift_card.enabled == false or gift_card.expired -%}
        <p class="badge badge--expired">{{ 'gift_cards.issued.expired' | t }}</p>
      {%- endif -%}

      {% if gift_card.expires_on %}
        {%- assign gift_card_expiration_date = gift_card.expires_on | date: '%B %e, %Y' -%}
        <p class="gift-card__expiration">
          {{ 'gift_cards.issued.expiration_date' | t: expires_on: gift_card_expiration_date }}
        </p>
      {% endif %}
    </header>

    <main class="gift-card__main-unit">
      <!-- QR Code Moved UP -->
      <div class="gift-card__qr-code" data-identifier="{{ gift_card.qr_identifier }}"></div>
      
      <h2 class="gift-card__shop-name">{{ shop.name }}</h2>
      
      <div class="gift-card__instructions">
        {{ 'gift_cards.issued.how_to_use_gift_card' | t }}
      </div>

      <!-- Special Message if present -->
      {%- if gift_card.message != blank -%}
        <div class="gift-card__message-box">
          <p class="message-label">Special Message:</p>
          <p class="message-content">"{{ gift_card.message }}"</p>
        </div>
      {%- endif -%}

      <div class="gift-card__code-container">
        <p id="gift-card-code" class="gift-card__number">{{ gift_card.code | format_code }}</p>
      </div>

      <div class="gift-card__actions no-print">
        {%- if gift_card.pass_url -%}
          <a href="{{ gift_card.pass_url }}" class="gift-card__apple-wallet">
            <img
              src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
              width="120"
              height="40"
              alt="{{ 'gift_cards.issued.add_to_apple_wallet' | t }}"
              loading="lazy"
            >
          </a>
        {%- endif -%}

        <div class="gift-card__copy-success form__message" role="status"></div>
        
        <template id="copy-success-template">
          <span class="svg-wrapper" style="width: 16px; height: 16px;">
             <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          </span>
          {{ 'gift_cards.issued.copy_code_success' | t }}
        </template>

        <div class="gift-card__buttons">
          <button class="button gift-card__copy-button">{{ 'gift_cards.issued.copy_code' | t }}</button>
          <button class="button button--secondary gift-card__print-button" onclick="window.print();">Print / Download</button>
          {%- if navigator.share -%}
            <button class="button button--secondary gift-card__share-button" id="share-button">Share Gift Card</button>
          {%- endif -%}
          <a
            href="{{ shop.url }}"
            class="button button--secondary gift-card__shop-btn"
            target="_blank"
            rel="noopener"
          >
            {{ 'gift_cards.issued.shop_link' | t }}
          </a>
        </div>
      </div>
    </main>

    <div hidden>
      <span id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</span>
    </div>
  </div>
</div>

<script>
  var string = { qrImageAlt: {{ 'gift_cards.issued.qr_image_alt' | t | json }} };
  document.addEventListener('DOMContentLoaded', function() {
    new QRCode( document.querySelector('.gift-card__qr-code'), {
      text: document.querySelector('.gift-card__qr-code').dataset.identifier,
      width: 120,
      height: 120,
      imageAltText: string.qrImageAlt
    });

    var copyButton = document.querySelector('.gift-card__copy-button');
    var successMessage = document.querySelector('.gift-card__copy-success');
    var template = document.getElementById("copy-success-template");
    var isMessageDisplayed = false;

    // Share button logic
    var shareButton = document.getElementById('share-button');
    if (shareButton) {
      shareButton.addEventListener('click', function() {
        if (navigator.share) {
          navigator.share({
            title: '{{ shop.name }} Gift Card',
            text: 'Check out this gift card from {{ shop.name }}!',
            url: window.location.href
          }).catch(console.error);
        }
      });
    }

    copyButton.addEventListener('click', function() {
      navigator.clipboard.writeText(document.getElementById('gift-card-code').innerText).then(function () {
        if (!isMessageDisplayed) {
          var clonedTemplate = template.content.cloneNode(true);
          successMessage.appendChild(clonedTemplate);
          isMessageDisplayed = true;
          
          setTimeout(function() {
            successMessage.innerHTML = '';
            isMessageDisplayed = false;
          }, 3000);
        }
      });
    });
  });
</script>
