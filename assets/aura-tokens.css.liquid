:root {
  /* ========================================
     BRAND COLORS — Editable from Shopify Theme Editor
     Theme Settings → "Aura Brand Colors"
     ======================================== */
  --aura-brand-gold: {{ settings.aura_gold }};
  --aura-brand-gold-light: {{ settings.aura_gold_light }};
  --aura-brand-bg-warm: {{ settings.aura_bg_warm }};
  --aura-brand-dark: {{ settings.brand_dark }};
  --aura-brand-dark-rgb: 26, 26, 26;
  --aura-brand-text-main: {{ settings.text_primary }};
  --aura-brand-text-muted: {{ settings.text_secondary }};
  --aura-brand-sale: {{ settings.sale_accent }};

  /* ========================================
     NEUTRAL COLORS — Editable from Shopify Theme Editor
     Theme Settings → "Aura Neutral Colors"
     ======================================== */
  --aura-white: #fff;
  --aura-black: #000;
  --aura-color-text-dark: {{ settings.brand_dark }};
  --aura-color-text-medium: {{ settings.aura_color_text_medium | default: '#333333' }};
  --aura-color-text-subtle: {{ settings.text_secondary }};
  --aura-color-text-muted: {{ settings.aura_color_text_muted | default: '#999999' }};
  --aura-color-border-light: {{ settings.aura_color_border_light | default: '#eeeeee' }};
  --aura-color-bg-subtle: {{ settings.aura_color_bg_subtle | default: '#f8f8f8' }};
  --aura-color-bg-warm: {{ settings.aura_bg_warm }};
  --aura-color-badge-dark: rgba(40, 40, 40, 0.8);

  /* ========================================
     OVERLAY UTILITIES — Derived, not editable
     ======================================== */
  --aura-overlay-dark-heavy: rgba(0, 0, 0, 0.5);
  --aura-overlay-dark-medium: rgba(0, 0, 0, 0.15);
  --aura-overlay-dark: rgba(0, 0, 0, 0.08);
  --aura-overlay-dark-subtle: rgba(0, 0, 0, 0.05);
  --aura-overlay-dark-xs: rgba(0, 0, 0, 0.03);
  --aura-overlay-white-heavy: rgba(255, 255, 255, 0.95);
  --aura-overlay-white: rgba(255, 255, 255, 0.75);
  --aura-overlay-white-subtle: rgba(255, 255, 255, 0.4);

  /* ========================================
     TYPOGRAPHY — Font Sizes
     Theme Settings → "Aura Typography & Shape"
     ======================================== */
  --aura-font-size-2xs: 1rem;
  --aura-font-size-xs: {{ settings.aura_font_size_xs | default: 11 }}px;
  --aura-font-size-sm: {{ settings.aura_font_size_sm | default: 13 }}px;
  --aura-font-size-base: {{ settings.aura_font_size_base | default: 15 }}px;
  --aura-font-size-md: {{ settings.aura_font_size_md | default: 18 }}px;
  --aura-font-size-lg: {{ settings.aura_font_size_lg | default: 24 }}px;
  --aura-font-size-xl: 3.2rem;
  --aura-font-size-xxl: 4.8rem;

  /* ========================================
     TYPOGRAPHY — Font Weights
     ======================================== */
  --aura-font-weight-light: 300;
  --aura-font-weight-normal: 400;
  --aura-font-weight-medium: 500;
  --aura-font-weight-semibold: 600;
  --aura-font-weight-bold: 700;
  --aura-font-weight-black: 900;

  /* ========================================
     SHAPE / RADII — Editable from Shopify Theme Editor
     Theme Settings → "Aura Typography & Shape"
     ======================================== */
  --aura-radius-xs: 4px;
  --aura-radius-sm: 6px;
  --aura-radius: {{ settings.aura_radius | default: 12 }}px;
  --aura-radius-lg: {{ settings.aura_radius_lg | default: 20 }}px;
  --aura-radius-xl: 24px;
  --aura-radius-pill: {{ settings.aura_btn_radius | default: 50 }}px;
  --aura-btn-radius: {{ settings.aura_btn_radius | default: 50 }}px;

  /* ========================================
     ANIMATION
     ======================================== */
  --aura-transition: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --aura-transition-spring: 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  --aura-transition-slow: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
