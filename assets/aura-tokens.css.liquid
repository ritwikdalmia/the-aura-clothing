:root {
  /* Dynamic Brand Solid Colors (Source of Truth) */
  --aura-brand-gold: {{ settings.aura_gold }};
  --aura-brand-gold-light: {{ settings.aura_gold_light }};
  --aura-brand-bg-warm: {{ settings.aura_bg_warm }};
  --aura-brand-dark: {{ settings.brand_dark }};
  --aura-brand-dark-rgb: 26, 26, 26; /* Default fallback, should ideally be dynamic */
  --aura-brand-text-main: {{ settings.text_primary }};
  --aura-brand-text-muted: {{ settings.text_secondary }};
  --aura-brand-sale: {{ settings.sale_accent }};

  /* Standardized Typography Tokens */
  --aura-font-size-xs: 1.1rem;
  --aura-font-size-sm: 1.3rem;
  --aura-font-size-base: 1.5rem;
  --aura-font-size-md: 1.8rem;
  --aura-font-size-lg: 2.4rem;
  --aura-font-size-xl: 3.2rem;
  --aura-font-size-xxl: 4.8rem;

  /* Global Transitions */
  --aura-transition: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --aura-radius: 12px;
  --aura-btn-radius: 50px;
}
