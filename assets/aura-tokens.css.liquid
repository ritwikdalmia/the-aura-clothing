:root {
  /* ========================================
     BRAND COLORS — Sourced from Theme Settings
     ======================================== */
  --aura-brand-gold: {{ settings.aura_gold }};
  --aura-brand-gold-light: {{ settings.aura_gold_light }};
  --aura-brand-bg-warm: {{ settings.aura_bg_warm }};
  --aura-brand-dark: {{ settings.brand_dark }};
  --aura-brand-dark-rgb: 26, 26, 26;
  --aura-brand-text-main: {{ settings.text_primary }};
  --aura-brand-text-muted: {{ settings.text_secondary }};
  --aura-brand-sale: {{ settings.sale_accent }};

  /* ========================================
     NEUTRAL COLORS — Change once, updates everywhere
     ======================================== */
  --aura-white: #fff;
  --aura-black: #000;
  --aura-color-text-dark: #1a1a1a;
  --aura-color-text-medium: #333;
  --aura-color-text-subtle: #666;
  --aura-color-text-muted: #999;
  --aura-color-border-light: #eee;
  --aura-color-bg-subtle: #f8f8f8;
  --aura-color-bg-warm: #fdfaf7;
  --aura-color-badge-dark: rgba(40, 40, 40, 0.8);

  /* ========================================
     OVERLAY UTILITIES
     ======================================== */
  --aura-overlay-dark-heavy: rgba(0, 0, 0, 0.5);
  --aura-overlay-dark-medium: rgba(0, 0, 0, 0.15);
  --aura-overlay-dark: rgba(0, 0, 0, 0.08);
  --aura-overlay-dark-subtle: rgba(0, 0, 0, 0.05);
  --aura-overlay-dark-xs: rgba(0, 0, 0, 0.03);
  --aura-overlay-white-heavy: rgba(255, 255, 255, 0.95);
  --aura-overlay-white: rgba(255, 255, 255, 0.75);
  --aura-overlay-white-subtle: rgba(255, 255, 255, 0.4);

  /* ========================================
     TYPOGRAPHY — Font Sizes
     ======================================== */
  --aura-font-size-2xs: 1rem;
  --aura-font-size-xs: 1.1rem;
  --aura-font-size-sm: 1.3rem;
  --aura-font-size-base: 1.5rem;
  --aura-font-size-md: 1.8rem;
  --aura-font-size-lg: 2.4rem;
  --aura-font-size-xl: 3.2rem;
  --aura-font-size-xxl: 4.8rem;

  /* ========================================
     TYPOGRAPHY — Font Weights
     ======================================== */
  --aura-font-weight-light: 300;
  --aura-font-weight-normal: 400;
  --aura-font-weight-medium: 500;
  --aura-font-weight-semibold: 600;
  --aura-font-weight-bold: 700;
  --aura-font-weight-black: 900;

  /* ========================================
     SPACING & LAYOUT
     ======================================== */
  --aura-radius-xs: 4px;
  --aura-radius-sm: 6px;
  --aura-radius: 12px;
  --aura-radius-lg: 20px;
  --aura-radius-xl: 24px;
  --aura-radius-pill: 50px;
  --aura-btn-radius: 50px;

  /* ========================================
     ANIMATION
     ======================================== */
  --aura-transition: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --aura-transition-spring: 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  --aura-transition-slow: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
