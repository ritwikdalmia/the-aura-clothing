{% comment %}
  Renders a premium 3D product card (The Aura custom)
{% endcomment %}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- if card_product and card_product != empty -%}
<div class="na-product-card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="na-card-image-wrapper">
      {%- if card_product.available == false -%}
        <span class="na-badge na-badge--sale" style="background: rgba(40,40,40,0.85); border: 1px solid rgba(255,255,255,0.15);">Sold out</span>
      {%- elsif card_product.compare_at_price > card_product.price and card_product.available -%}
        <span class="na-badge na-badge--sale">Sale</span>
      {%- endif -%}

      {%- if card_product.tags contains 'New' or card_product.tags contains 'new' -%}
        <span class="na-badge na-badge--new" style="{% if card_product.compare_at_price > card_product.price or card_product.available == false %}top: 48px;{% endif %}">New</span>
      {%- endif -%}

      <button class="na-wishlist" aria-label="Add to wishlist" onclick="event.preventDefault(); event.stopPropagation(); toggleWishlist(this, '{{ card_product.id }}')">
        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>

      <a href="{{ card_product.url }}" class="na-card-image-link">
        {%- if card_product.featured_media -%}
          <img
            class="na-card-img-primary"
            src="{{ card_product.featured_media | image_url: width: 600 }}"
            alt="{{ card_product.featured_media.alt | escape }}"
            loading="{% if lazy_load == false %}eager{% else %}lazy{% endif %}"
            width="{{ card_product.featured_media.width }}"
            height="{{ card_product.featured_media.height }}"
          >
          {%- if card_product.media[1] and show_secondary_image -%}
            <img
              class="na-card-img-hover"
              src="{{ card_product.media[1] | image_url: width: 600 }}"
              alt="{{ card_product.media[1].alt | escape }}"
              loading="lazy"
              width="{{ card_product.media[1].width }}"
              height="{{ card_product.media[1].height }}"
            >
          {%- endif -%}
        {%- else -%}
          {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg na-card-img-primary' }}
        {%- endif -%}
      </a>
      
      <div class="na-quick-add" onclick="event.preventDefault(); event.stopPropagation(); openQuickAdd('{{ card_product.url }}')">Quick Add</div>
    </div>
    
    <a href="{{ card_product.url }}" class="na-card-info">
      <h3 class="na-card-title">{{ card_product.title }}</h3>
      <div class="na-card-price-row">
        <span class="na-card-price">{{ card_product.price | money }}</span>
        {%- if card_product.compare_at_price > card_product.price and card_product.available -%}
          <span class="na-card-compare-price">{{ card_product.compare_at_price | money }}</span>
          {%- assign savings = card_product.compare_at_price | minus: card_product.price | times: 100 | divided_by: card_product.compare_at_price -%}
          <span class="na-card-discount">-{{ savings }}%</span>
        {%- endif -%}
      </div>
    </a>
  </div>
{%- else -%}
  <div class="na-product-card">
    <div class="na-card-image-wrapper">
      {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg na-card-img-primary' }}
      <div class="na-quick-add">Quick Add</div>
    </div>
    <div class="na-card-info">
      <h3 class="na-card-title">{{ 'onboarding.product_title' | t }}</h3>
      <div class="na-card-price-row">
        <span class="na-card-price">{{ 1999 | money }}</span>
      </div>
    </div>
  </div>
{%- endif -%}
