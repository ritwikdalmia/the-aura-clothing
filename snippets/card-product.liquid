{% comment %}
  Renders a premium 3D product card (The Aura custom)
{% endcomment %}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- if card_product and card_product != empty -%}
<a href="{{ card_product.url }}" class="na-product-card color-{{ settings.card_color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="na-card-image-wrapper">
      <div class="na-badge-container">
        {%- if card_product.available == false -%}
          <span class="na-badge na-badge--sold-out">Sold out</span>
        {%- elsif card_product.compare_at_price > card_product.price and card_product.available -%}
          {%- assign savings = card_product.compare_at_price | minus: card_product.price | times: 100 | divided_by: card_product.compare_at_price -%}
          <span class="na-badge na-badge--sale">Sale -{{ savings }}%</span>
        {%- endif -%}

        {%- liquid
          assign date_now = 'now' | date: '%s'
          assign date_published = card_product.published_at | date: '%s'
          assign diff_seconds = date_now | minus: date_published
          assign is_new = false
          if diff_seconds < 2592000
            assign is_new = true
          endif
        -%}

        {%- if card_product.tags contains 'Best Seller' or card_product.tags contains 'best-seller' or card_product.tags contains 'Best' -%}
          <span class="na-badge na-badge--best">Best Seller</span>
        {%- elsif is_new or card_product.tags contains 'New' or card_product.tags contains 'new' -%}
          <span class="na-badge na-badge--new">New</span>
        {%- endif -%}
      </div>

      <button class="aura-action-btn na-wishlist" aria-label="Add to wishlist" data-aura-wishlist="{{ card_product.handle }}">
        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>

      <button class="aura-action-btn na-compare" aria-label="Add to compare" 
        data-aura-compare="{{ card_product.handle }}"
        {%- liquid
          assign specs = ''
          for metafield in card_product.metafields.custom limit: 5
            assign key = metafield | first
            assign val_obj = metafield | last
            assign val = val_obj.value
            
            if val.label != blank
              assign display_val = val.label
            elsif val.name != blank
              assign display_val = val.name
            else
              assign display_val = val | escape
            endif
            
            assign specs = specs | append: key | append: ': ' | append: display_val | append: '|'
          endfor
        -%}
        data-aura-specs="{{ specs | escape }}"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"></polyline><line x1="4" y1="20" x2="21" y2="3"></line><polyline points="21 16 21 21 16 21"></polyline><line x1="15" y1="15" x2="21" y2="21"></line><line x1="4" y1="4" x2="9" y2="9"></line></svg>
      </button>

      <div class="na-collection-slideshow">
        {%- if card_product.media.size > 0 -%}
          {%- for media in card_product.media limit: 2 -%}
            {%- assign image_loading = 'lazy' -%}
            {%- if lazy_load == false -%}
              {%- assign image_loading = 'eager' -%}
            {%- endif -%}

            {{ media.preview_image | image_url: width: 600 | image_tag:
              loading: image_loading,
              sizes: '(min-width: 1200px) 300px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)',
              widths: '200, 300, 400, 500, 600, 700, 800',
              class: 'na-card-img',
              style: 'animation-delay: ' | append: forloop.index0 | append: 's'
            }}
          {%- endfor -%}
        {%- else -%}
           {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg na-card-img-primary' }}
        {%- endif -%}
      </div>
      
      {%- if card_product.available -%}
        <div class="na-quick-add" data-aura-quick-add="{{ card_product.url }}">Quick Add</div>
      {%- endif -%}
    </div>
    
    <div class="na-card-info">
      <h3 class="na-card-title">{{ card_product.title }}</h3>
      
      <div class="na-card-price-row">
        {%- if card_product.compare_at_price > card_product.price and card_product.available -%}
          <span class="na-card-compare-price">{{ card_product.compare_at_price | money }}</span>
          <span class="na-card-price">{% if card_product.price_varies %}From {% endif %}{{ card_product.price | money }}</span>
        {%- else -%}
          <span class="na-card-price">{% if card_product.price_varies %}From {% endif %}{{ card_product.price | money }}</span>
        {%- endif -%}
      </div>

      <div class="na-mobile-actions">
         <button class="na-wishlist-mobile" aria-label="Add to wishlist" data-aura-wishlist="{{ card_product.handle }}">
           <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
         </button>
         <button class="na-compare-mobile" aria-label="Add to compare" data-aura-compare="{{ card_product.handle }}" data-aura-specs="{{ specs | escape }}">
           <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"></polyline><line x1="4" y1="20" x2="21" y2="3"></line><polyline points="21 16 21 21 16 21"></polyline><line x1="15" y1="15" x2="21" y2="21"></line><line x1="4" y1="4" x2="9" y2="9"></line></svg>
         </button>
      </div>
    </div>
  </a>
{%- else -%}
  <div class="na-product-card">
    <div class="na-card-image-wrapper">
      {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg na-card-img-primary' }}
      <div class="na-quick-add">Quick Add</div>
    </div>
    <div class="na-card-info">
      <h3 class="na-card-title">{{ 'onboarding.product_title' | t }}</h3>
      <div class="na-card-price-row">
        <span class="na-card-price">{{ 1999 | money }}</span>
      </div>
    </div>
  </div>
{%- endif -%}
