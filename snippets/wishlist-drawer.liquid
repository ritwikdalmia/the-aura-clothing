<style>
  .wishlist-drawer {
    visibility: hidden;
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    z-index: 10000;
    display: flex;
    justify-content: flex-end;
    transition: visibility 0.3s ease;
  }
  .wishlist-drawer.is-open {
    visibility: visible;
  }
  .wishlist-drawer__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .wishlist-drawer.is-open .wishlist-drawer__overlay {
    opacity: 1;
  }
  .wishlist-drawer__inner {
    position: relative;
    width: 100%;
    max-width: 400px;
    height: 100%;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -20px 0 50px rgba(0,0,0,0.15);
    border-left: 1px solid rgba(255,255,255,0.3);
  }
  .wishlist-drawer.is-open .wishlist-drawer__inner {
    transform: translateX(0);
  }
  .wishlist-drawer__header {
    padding: 3rem 2.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .wishlist-drawer__header h2 {
    margin: 0;
    font-weight: 600;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
    font-size: 1.6rem;
  }
  .wishlist-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: 2.5rem;
  }

  /* Custom Scrollbar */
  .wishlist-drawer__content::-webkit-scrollbar {
    width: 5px;
  }
  .wishlist-drawer__content::-webkit-scrollbar-track {
    background: rgba(0,0,0,0.02);
  }
  .wishlist-drawer__content::-webkit-scrollbar-thumb {
    background: #a88b6a;
    border-radius: 10px;
  }
  .wishlist-drawer__content::-webkit-scrollbar-thumb:hover {
    background: #967a5b;
  }
  .wishlist-item {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.03);
    position: relative;
    animation: auraFadeInUp 0.5s ease backwards;
  }

  @keyframes auraFadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .wishlist-item__image {
    width: 90px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: 12px;
    background: #fdfaf7;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }
  .wishlist-item__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .wishlist-item__title {
    margin: 0 0 0.8rem;
    font-size: 1.4rem;
    font-weight: 500;
  }
  .wishlist-item__title a {
    text-decoration: none;
    color: inherit;
  }
  .wishlist-item__price {
    font-size: 1.5rem;
    color: #121212;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .wishlist-item__remove {
    position: absolute;
    top: 0;
    right: 0;
    background: #fff;
    border: none;
    cursor: pointer;
    color: #121212;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
  }
  .wishlist-item__remove:hover {
    background: #000;
    color: #fff;
    transform: scale(1.1);
  }
  .wishlist-drawer__empty {
    text-align: center;
    padding: 6rem 2rem;
  }
  .wishlist-drawer__empty p {
    font-size: 1.6rem;
    color: #666;
    margin-bottom: 2rem;
  }
</style>

<div id="WishlistDrawer" class="wishlist-drawer">
  <div class="wishlist-drawer__overlay" onclick="closeWishlist()"></div>
  <div class="wishlist-drawer__inner">
    <div class="wishlist-drawer__header">
      <h2 class="h3">Wishlist (<span class="aura-wishlist-count">0</span>)</h2>
      <button class="drawer__close-btn" onclick="closeWishlist()" style="background: none; border: none; cursor: pointer; padding: 1.5rem; display: flex; align-items: center; justify-content: center; color: #121212; transition: transform 0.3s ease;">
        <span class="svg-wrapper" style="width: 2.2rem; height: 2.2rem; display: block;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </span>
      </button>
    </div>
    <div class="wishlist-drawer__content" id="WishlistContent">
      <!-- Content populated by JS -->
    </div>
  </div>
</div>

<script>
  function openWishlist() {
    document.getElementById('WishlistDrawer').classList.add('is-open');
    renderWishlist();
  }

  function closeWishlist() {
    document.getElementById('WishlistDrawer').classList.remove('is-open');
  }

  async function renderWishlist() {
    const container = document.getElementById('WishlistContent');
    const handles = window.AuraFeatures.getWishlist();
    
    if (handles.length === 0) {
      container.innerHTML = '<div class="wishlist-drawer__empty"><p>Your wishlist is empty.</p><a href="/collections/all" class="button">Continue Shopping</a></div>';
      return;
    }

    container.innerHTML = '<div style="display: flex; justify-content: center; padding: 4rem;"><div class="loading-spinner"></div></div>';

    let html = '';
    for (const handle of handles) {
      try {
        const response = await fetch(`/products/${handle}.js`);
        if (!response.ok) throw new Error('Product not found');
        const product = await response.json();
        
        const formattedPrice = window.AuraFeatures.formatMoney(product.price);
        
        html += `
          <div class="wishlist-item" style="animation-delay: ${html.length * 0.001}s">
            <img class="wishlist-item__image" src="${product.featured_image}" alt="${product.title}">
            <div class="wishlist-item__info">
              <h3 class="wishlist-item__title"><a href="${product.url}">${product.title}</a></h3>
              <p class="wishlist-item__price">${formattedPrice}</p>
              <button class="button button--secondary button--small" style="border-radius: 50px; font-size: 1.1rem; padding: 0.8rem 1.5rem;" onclick="addToCartFromWishlist('${product.variants[0].id}', this)">Add to Cart</button>
            </div>
            <button class="wishlist-item__remove" onclick="window.AuraFeatures.toggleWishlist('${handle}'); renderWishlist();">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>
        `;
      } catch (e) {
        console.error('Error fetching wishlist product:', e);
      }
    }
    container.innerHTML = html || '<div class="wishlist-drawer__empty"><p>Error loading products.</p></div>';
  }

  function addToCartFromWishlist(variantId, btn) {
    const originalText = btn.textContent;
    btn.textContent = 'Adding...';
    btn.disabled = true;

    fetch(window.routes.cart_add_url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
    })
    .then(response => response.json())
    .then(data => {
      btn.textContent = 'Added!';
      // Trigger cart drawer open if available
      if (typeof cartDrawer !== 'undefined' || document.querySelector('cart-drawer')) {
        const cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer && cartDrawer.open) cartDrawer.open();
        closeWishlist();
      }
      setTimeout(() => {
        btn.textContent = originalText;
        btn.disabled = false;
      }, 2000);
    })
    .catch(error => {
      console.error('Error adding to cart:', error);
      btn.textContent = 'Error';
      btn.disabled = false;
    });
  }
</script>
