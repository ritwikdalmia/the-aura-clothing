<style>
  /* ============================================================
     Aura Wishlist Drawer – Premium Redesign
     ============================================================ */

  .wishlist-drawer {
    visibility: hidden;
    position: fixed;
    inset: 0;
    z-index: 2147483647;
    display: flex;
    justify-content: flex-end;
    transition: visibility 0s linear 0.45s;
    pointer-events: none;
  }
  .wishlist-drawer.is-open {
    visibility: visible;
    transition-delay: 0s;
    pointer-events: auto;
  }

  /* Backdrop */
  .wishlist-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(var(--aura-brand-dark-rgb), 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.4s ease;
    cursor: pointer;
  }
  .wishlist-drawer.is-open .wishlist-drawer__overlay {
    opacity: 1;
  }

  /* Panel */
  .wishlist-drawer__inner {
    position: relative;
    width: min(420px, 100vw);
    height: 100%;
    background: var(--aura-brand-bg-warm);
    transform: translateX(105%);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -24px 0 60px rgba(0, 0, 0, 0.18);
    border-left: 1px solid rgba(var(--aura-brand-gold-rgb), 0.12);
    overflow: hidden;
  }
  .wishlist-drawer.is-open .wishlist-drawer__inner {
    transform: translateX(0);
  }

  /* Gold accent edge line */
  .wishlist-drawer__inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(
      to bottom,
      var(--aura-brand-gold),
      transparent 60%
    );
    opacity: 0.6;
    z-index: 1;
  }

  /* ── Header ── */
  .wishlist-drawer__header {
    padding: 2.4rem 2.5rem 2rem;
    border-bottom: 1px solid rgba(var(--aura-brand-dark-rgb), 0.06);
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(var(--color-background), 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    flex-shrink: 0;
  }

  .wishlist-drawer__header-icon {
    color: var(--aura-brand-gold);
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .wishlist-drawer__header-title {
    flex: 1;
    margin: 0;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--aura-brand-text-main);
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    white-space: nowrap;
  }

  .wishlist-drawer__count-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--aura-brand-gold) !important;
    color: #fff !important;
    font-size: 1rem;
    font-weight: 700;
    min-width: 2rem;
    height: 2rem;
    border-radius: 50px;
    padding: 0 0.6rem;
    line-height: 1;
    letter-spacing: 0;
  }

  .wishlist-drawer__close {
    width: 4rem;
    height: 4rem;
    flex-shrink: 0;
    border: none;
    background: var(--aura-brand-gold);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 4px 15px rgba(var(--aura-brand-gold-rgb), 0.35);
  }
  .wishlist-drawer__close:hover {
    background: var(--aura-brand-text-main);
    color: #fff;
    transform: rotate(90deg) scale(1.1);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
  }

  /* ── Scrollable Items ── */
  .wishlist-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: 2rem 2rem 1rem;
    scroll-behavior: smooth;
  }

  /* Custom Scrollbar */
  .wishlist-drawer__content::-webkit-scrollbar {
    width: 4px;
  }
  .wishlist-drawer__content::-webkit-scrollbar-track {
    background: transparent;
  }
  .wishlist-drawer__content::-webkit-scrollbar-thumb {
    background: rgba(184, 152, 102, 0.4);
    border-radius: 10px;
  }
  .wishlist-drawer__content::-webkit-scrollbar-thumb:hover {
    background: var(--aura-brand-gold);
  }

  /* ── Wishlist Item ── */
  .wishlist-item {
    display: grid;
    grid-template-columns: 88px 1fr;
    grid-template-rows: auto;
    gap: 0 1.4rem;
    position: relative;
    padding: 1.6rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    animation: wlFadeUp 0.45s cubic-bezier(0.22, 1, 0.36, 1) backwards;
  }
  .wishlist-item:last-child {
    border-bottom: none;
  }

  @keyframes wlFadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .wishlist-item__image-link {
    grid-row: 1 / 3;
    display: block;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .wishlist-item__image {
    width: 88px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    background: var(--aura-brand-gold-light);
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .wishlist-item__image-link:hover .wishlist-item__image {
    transform: scale(1.05);
  }

  .wishlist-item__meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-right: 3rem; /* room for remove btn */
  }

  .wishlist-item__vendor {
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--aura-brand-text-muted);
    font-weight: 600;
    margin: 0;
    line-height: 1;
  }

  .wishlist-item__title {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--aura-brand-text-main);
  }
  .wishlist-item__title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s ease;
  }
  .wishlist-item__title a:hover {
    color: var(--aura-brand-gold);
  }

  .wishlist-item__price-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-top: 0.2rem;
  }

  .wishlist-item__price {
    font-size: 1.3rem;
    color: var(--aura-brand-text-muted);
    font-weight: 400;
    letter-spacing: 0.01em;
  }
  /* Gold colour when item is on sale */
  .wishlist-item__price--sale {
    color: var(--aura-brand-gold);
    font-weight: 500;
  }
  .wishlist-item__price-compare {
    font-size: 1.2rem;
    color: var(--aura-brand-text-muted);
    opacity: 0.6;
    text-decoration: line-through;
    font-weight: 400;
  }

  /* Add to cart button */
  .wishlist-item__add-btn {
    margin-top: 1rem;
    width: 100%;
    padding: 0.9rem 1.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1.5px solid var(--aura-brand-gold);
    border-radius: 50px;
    background: transparent;
    color: var(--aura-brand-gold);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    max-width: 190px;
  }
  .wishlist-item__add-btn:hover:not(:disabled) {
    background: var(--aura-brand-gold);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(184, 152, 102, 0.35);
  }
  .wishlist-item__add-btn:disabled {
    opacity: 0.65;
    cursor: default;
  }
  .wishlist-item__add-btn.is-added {
    background: var(--aura-brand-text-main);
    border-color: var(--aura-brand-text-main);
    color: #fff;
  }

  /* Remove button */
  .wishlist-item__remove {
    position: absolute;
    top: 1.4rem;
    right: 0;
    width: 2.8rem;
    height: 2.8rem;
    background: rgba(var(--aura-brand-dark-rgb), 0.04);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--aura-brand-text-muted);
    transition: all 0.25s ease;
    flex-shrink: 0;
    padding: 0;
  }
  .wishlist-item__remove:hover {
    background: rgba(var(--aura-brand-sale-rgb), 0.08);
    color: var(--aura-brand-sale);
    transform: scale(1.1);
  }

  /* ── Loading Skeleton ── */
  .wl-skeleton {
    padding: 1.6rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 0 1.4rem;
  }
  .wl-skeleton__img {
    width: 88px;
    aspect-ratio: 3 / 4;
    border-radius: 10px;
    background: linear-gradient(90deg, #f0e9e0 25%, #e8ddd3 50%, #f0e9e0 75%);
    background-size: 200% 100%;
    animation: wlShimmer 1.4s infinite;
  }
  .wl-skeleton__lines {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding-top: 0.4rem;
  }
  .wl-skeleton__line {
    height: 1.2rem;
    border-radius: 6px;
    background: linear-gradient(90deg, #f0e9e0 25%, #e8ddd3 50%, #f0e9e0 75%);
    background-size: 200% 100%;
    animation: wlShimmer 1.4s infinite;
  }
  .wl-skeleton__line--short { width: 50%; }
  .wl-skeleton__line--price { width: 40%; height: 1.6rem; }
  .wl-skeleton__line--btn { width: 65%; height: 3.2rem; border-radius: 50px; margin-top: 0.4rem; }
  @keyframes wlShimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Empty State ── */
  .wishlist-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 5rem 3rem 3rem;
    animation: wlFadeUp 0.5s ease backwards;
  }
  .wishlist-drawer__empty-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(184, 152, 102, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    color: var(--aura-brand-gold);
  }
  .wishlist-drawer__empty h3 {
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    margin: 0 0 0.8rem;
    color: var(--aura-brand-text-main);
  }
  .wishlist-drawer__empty p {
    font-size: 1.35rem;
    color: var(--aura-brand-text-muted);
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }
  .wishlist-drawer__empty .wl-shop-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--aura-brand-gold);
    color: #fff;
    padding: 1.2rem 3rem;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 6px 20px rgba(184, 152, 102, 0.3);
  }
  .wishlist-drawer__empty .wl-shop-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(184, 152, 102, 0.4);
  }

  /* ── Footer ── */
  .wishlist-drawer__footer {
    flex-shrink: 0;
    padding: 1.6rem 2rem 2rem;
    border-top: 1px solid rgba(var(--aura-brand-dark-rgb), 0.06);
    background: rgba(var(--color-background), 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .wishlist-drawer__footer-note {
    font-size: 1.1rem;
    color: var(--aura-brand-text-muted);
    opacity: 0.7;
    line-height: 1.5;
    flex: 1;
  }
  .wishlist-drawer__clear-btn {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--aura-brand-text-muted);
    opacity: 0.5;
    padding: 0.5rem;
    transition: color 0.25s ease, opacity 0.25s ease;
    white-space: nowrap;
  }
  .wishlist-drawer__clear-btn:hover {
    color: var(--aura-brand-sale);
    opacity: 1;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 480px) {
    .wishlist-drawer__inner {
      width: 100vw;
    }
    .wishlist-item__add-btn {
      max-width: 100%;
    }
  }
</style>

<div id="WishlistDrawer" class="wishlist-drawer" role="dialog" aria-modal="true" aria-label="Wishlist">
  <div class="wishlist-drawer__overlay" onclick="closeWishlist()" aria-hidden="true"></div>
  <div class="wishlist-drawer__inner">

    <!-- Header -->
    <div class="wishlist-drawer__header">
      <div class="wishlist-drawer__header-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </div>
      <h2 class="wishlist-drawer__header-title">
        Wishlist
        <span class="wishlist-drawer__count-pill aura-wishlist-count">0</span>
      </h2>
      <button class="wishlist-drawer__close" onclick="closeWishlist()" aria-label="Close wishlist">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Items -->
    <div class="wishlist-drawer__content" id="WishlistContent">
      <!-- Populated by JS -->
    </div>

    <!-- Footer -->
    <div class="wishlist-drawer__footer" id="WishlistFooter" style="display:none;">
      <p class="wishlist-drawer__footer-note">Saved items are stored on this device.</p>
      <button class="wishlist-drawer__clear-btn" onclick="clearWishlist()">Clear all</button>
    </div>

  </div>
</div>

<script>
  /* ────────────────────────────────────────────────
     Aura Wishlist Drawer — Controller
  ──────────────────────────────────────────────── */

  function openWishlist() {
    const drawer = document.getElementById('WishlistDrawer');
    drawer.classList.add('is-open');

    // Offset for announcement bar so it doesn't overlap
    const announcementBar = document.querySelector('.shopify-section-announcement-bar, .announcement-bar, [class*="announcement"], #shopify-section-announcement-bar');
    let offset = 0;
    if (announcementBar) {
      const rect = announcementBar.getBoundingClientRect();
      if (rect.top <= 0) {
        offset = rect.height;
      }
    }
    const inner = drawer.querySelector('.wishlist-drawer__inner');
    if (inner) {
      inner.style.paddingTop = offset > 0 ? (offset + 10) + 'px' : '';
    }

    document.body.style.overflow = 'hidden';
    renderWishlist();
  }

  function closeWishlist() {
    const drawer = document.getElementById('WishlistDrawer');
    drawer.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeWishlist();
  });

  function clearWishlist() {
    if (!confirm('Remove all items from your wishlist?')) return;
    localStorage.setItem(window.AuraFeatures.WISHLIST_KEY, JSON.stringify([]));
    window.AuraFeatures.updateBadges();
    renderWishlist();
  }

  /* Skeleton loader */
  function renderSkeletons(n) {
    return Array.from({ length: n }, () => `
      <div class="wl-skeleton">
        <div class="wl-skeleton__img"></div>
        <div class="wl-skeleton__lines">
          <div class="wl-skeleton__line wl-skeleton__line--short"></div>
          <div class="wl-skeleton__line"></div>
          <div class="wl-skeleton__line wl-skeleton__line--price"></div>
          <div class="wl-skeleton__line wl-skeleton__line--btn"></div>
        </div>
      </div>
    `).join('');
  }

  async function renderWishlist() {
    const container = document.getElementById('WishlistContent');
    const footer    = document.getElementById('WishlistFooter');
    const handles   = window.AuraFeatures.getWishlist();

    /* Update the count pills */
    document.querySelectorAll('.wishlist-drawer__count-pill').forEach(el => {
      el.textContent = handles.length;
    });

    if (handles.length === 0) {
      footer.style.display = 'none';
      container.innerHTML = `
        <div class="wishlist-drawer__empty">
          <div class="wishlist-drawer__empty-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h3>Your wishlist is empty</h3>
          <p>Save pieces you love and find them here whenever you're ready.</p>
          <a href="/collections/all" class="wl-shop-link" onclick="closeWishlist()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            Shop the Edit
          </a>
        </div>`;
      return;
    }

    /* Show skeletons while loading */
    container.innerHTML = renderSkeletons(Math.min(handles.length, 4));
    footer.style.display = 'none';

    /* Fetch all products in parallel */
    const results = await Promise.allSettled(
      handles.map(h => fetch(`/products/${h}.js`).then(r => r.ok ? r.json() : Promise.reject()))
    );

    let html = '';
    let index = 0;

    for (const result of results) {
      if (result.status !== 'fulfilled') { index++; continue; }
      const product = result.value;
      const handle  = handles[index];
      const delay   = (index * 0.07).toFixed(2);

      const price = product.price_varies
        ? `${window.AuraFeatures.formatMoney(product.price_min)} — ${window.AuraFeatures.formatMoney(product.price_max)}`
        : window.AuraFeatures.formatMoney(product.price);

      const comparePrice = product.compare_at_price && product.compare_at_price > product.price
        ? window.AuraFeatures.formatMoney(product.compare_at_price)
        : null;
      const savings = comparePrice
        ? Math.round((1 - product.price / product.compare_at_price) * 100)
        : 0;

      const vendor = product.vendor
        ? `<p class="wishlist-item__vendor">${product.vendor}</p>`
        : '';
      const compareHtml = comparePrice
        ? `<s class="wishlist-item__price-compare">${comparePrice}</s>`
        : '';

      /* Use first available variant */
      const firstVariant = product.variants && product.variants[0];
      const variantId    = firstVariant ? firstVariant.id : null;
      const available    = firstVariant ? firstVariant.available : false;

      const addBtnText = !available ? 'Sold Out' : 'Add to Cart';
      const addBtnDisabled = !available ? 'disabled' : '';

      html += `
        <div class="wishlist-item" style="animation-delay:${delay}s">
          <a class="wishlist-item__image-link" href="${product.url}" onclick="closeWishlist()">
            <img
              class="wishlist-item__image"
              src="${product.featured_image}"
              alt="${product.title}"
              loading="lazy"
              width="88"
              height="117"
            >
          </a>
          <div class="wishlist-item__meta">
            ${vendor}
            <h3 class="wishlist-item__title">
              <a href="${product.url}" onclick="closeWishlist()">${product.title}</a>
            </h3>
            <div class="wishlist-item__price-row">
              ${compareHtml}
              <span class="wishlist-item__price${comparePrice ? ' wishlist-item__price--sale' : ''}">${price}</span>
            </div>
            <button
              class="wishlist-item__add-btn"
              ${addBtnDisabled}
              onclick="addToCartFromWishlist(${variantId}, this, '${handle}')"
              data-variant-id="${variantId}"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
              ${addBtnText}
            </button>
          </div>
          <button
            class="wishlist-item__remove"
            onclick="removeFromWishlist('${handle}', this)"
            aria-label="Remove ${product.title} from wishlist"
            title="Remove item"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              <line x1="10" y1="11" x2="10" y2="17"></line>
              <line x1="14" y1="11" x2="14" y2="17"></line>
            </svg>
          </button>
        </div>
      `;
      index++;
    }

    container.innerHTML = html || `
      <div class="wishlist-drawer__empty">
        <div class="wishlist-drawer__empty-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <h3>Couldn't load items</h3>
        <p>Please try refreshing the page.</p>
      </div>`;

    footer.style.display = html ? 'flex' : 'none';
  }

  /* Remove a single item with animation */
  function removeFromWishlist(handle, btn) {
    const item = btn.closest('.wishlist-item');
    if (item) {
      item.style.transition = 'opacity 0.3s ease, transform 0.3s ease, max-height 0.35s ease';
      item.style.opacity  = '0';
      item.style.transform = 'translateX(20px)';
      item.style.maxHeight = item.offsetHeight + 'px';
      item.style.overflow  = 'hidden';
      setTimeout(() => {
        item.style.maxHeight = '0';
        item.style.padding   = '0';
        item.style.margin    = '0';
      }, 280);
      setTimeout(() => {
        item.remove();
        window.AuraFeatures.toggleWishlist(handle);
        /* Update count pill directly without re-rendering */
        const remaining = window.AuraFeatures.getWishlist().length;
        document.querySelectorAll('.wishlist-drawer__count-pill').forEach(el => el.textContent = remaining);
        const footer = document.getElementById('WishlistFooter');
        if (remaining === 0) {
          if (footer) footer.style.display = 'none';
          renderWishlist();
        }
      }, 600);
    }
  }

  /* Add to cart */
  function addToCartFromWishlist(variantId, btn) {
    if (!variantId) return;
    const label = btn.innerHTML;
    btn.innerHTML = `
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke-dasharray="63" stroke-dashoffset="63" style="animation:wlSpin 0.8s linear infinite"/>
      </svg>
      Adding…`;
    btn.disabled = true;

    fetch(window.routes.cart_add_url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
    })
    .then(r => r.json())
    .then(() => {
      btn.innerHTML = `
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Added!`;
      btn.classList.add('is-added');

      /* Refresh cart bubble */
      document.dispatchEvent(new CustomEvent('cart:refresh'));

      /* Open cart drawer if available */
      const cartDrawerEl = document.querySelector('cart-drawer');
      if (cartDrawerEl && typeof cartDrawerEl.open === 'function') {
        closeWishlist();
        cartDrawerEl.open();
      }

      setTimeout(() => {
        btn.innerHTML  = label;
        btn.disabled   = false;
        btn.classList.remove('is-added');
      }, 2500);
    })
    .catch(() => {
      btn.innerHTML = 'Error — try again';
      btn.disabled  = false;
      setTimeout(() => { btn.innerHTML = label; }, 2000);
    });
  }
</script>
