{% comment %}
  Renders the premium Quick Add modal content
  Usage:
  {% render 'product-quick-add', product: product %}
{% endcomment %}

<div class="na-modal-body">
  <div class="na-quick-view-media">
    <div class="na-qv-carousel">
      {%- for media in product.media -%}
        <div class="na-qv-slide {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
           <img src="{{ media | image_url: width: 800 }}" 
                alt="{{ media.alt | escape }}"
                width="800"
                height="{{ 800 | divided_by: media.aspect_ratio }}"
                loading="lazy">
        </div>
      {%- endfor -%}
    </div>
  </div>
  
  <div class="na-quick-view-info">
    <div class="na-qv-header">
      <p class="caption-with-letter-spacing light" style="margin-bottom: 0.5rem; color: #999;">{{ product.vendor }}</p>
      <h2 class="na-qv-title">{{ product.title }}</h2>
      
      <div class="na-qv-price-row" id="naQvPrice-{{ section.id }}">
        {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
          <span class="na-qv-compare-price">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
          <span class="na-qv-price">{{ product.selected_or_first_available_variant.price | money }}</span>
        {%- else -%}
          <span class="na-qv-price">{{ product.selected_or_first_available_variant.price | money }}</span>
        {%- endif -%}
      </div>
      {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
        <div class="na-qv-badge-row">
          {%- assign savings = product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100 | divided_by: product.selected_or_first_available_variant.compare_at_price -%}
          <span class="na-qv-badge">-{{ savings }}% SALE</span>
        </div>
      {%- endif -%}
    </div>

    <div class="na-qv-variants">
      {%- for option in product.options_with_values -%}
        {%- assign downcase_option = option.name | downcase -%}
        {%- assign is_color = false -%}
        {%- if downcase_option contains 'color' or downcase_option contains 'colour' -%}
          {%- assign is_color = true -%}
        {%- endif -%}

        <div class="na-qv-option-wrapper" data-option-index="{{ forloop.index0 }}">
          <h4 class="na-qv-option-title">{{ option.name }}</h4>
          <div class="na-qv-options {% if is_color %}na-qv-color-options{% endif %}">
            {%- for value in option.values -%}
              <div class="na-qv-option{% if option.selected_value == value %} active{% endif %}{% if is_color %} na-qv-swatch{% endif %}" 
                   data-value="{{ value | escape }}"
                   {% if is_color %}title="{{ value | escape }}" data-color-name="{{ value | escape }}"{% endif %}>
                {%- if is_color -%}
                  {%- liquid
                    assign swatch_value = null
                    if value.swatch.image
                      assign image_url = value.swatch.image | image_url: width: 50
                      assign swatch_value = 'url(' | append: image_url | append: ')'
                    elsif value.swatch.color
                      assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                    endif
                  -%}
                  <span class="na-qv-swatch-inner" style="background: {{ swatch_value | default: value | escape }};"></span>
                {%- else -%}
                  {{ value }}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="na-qv-qty-row">
      <h4 class="na-qv-option-title" style="margin-bottom: 0;">Quantity</h4>
      <div class="na-qv-qty-input">
        <button type="button" class="na-qv-qty-btn minus" data-aura-qty-minus>&minus;</button>
        <input type="number" class="na-qv-qty-val" value="1" min="1" readonly>
        <button type="button" class="na-qv-qty-btn plus" data-aura-qty-plus>&plus;</button>
      </div>
    </div>

    <button type="button" 
            class="na-qv-add-btn aura-btn-premium" 
            data-aura-add-to-cart
            data-variant-id="{{ product.selected_or_first_available_variant.id }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      Add to cart
    </button>
    
    <button type="button" 
            class="na-qv-buy-btn aura-btn-premium" 
            data-aura-buy-now
            data-variant-id="{{ product.selected_or_first_available_variant.id }}">
      Buy it now
    </button>

    {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' and product.selected_or_first_available_variant.inventory_quantity > 0 and product.selected_or_first_available_variant.inventory_quantity < 10 -%}
      <div class="na-qv-urgency">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c1 2 2 3.5 3 5.5.5 1 1 2.1 1 3.5 0 3-1 4-1 4a2.5 2.5 0 0 1-5 0s-1-1-1-4c0-1.4.5-2.5 1-3.5 1-2 2-3.5 3-5.5Z"></path><path d="M10 18c0 1.4 0 2.6 1 3.5a2.5 2.5 0 0 0 5 0c0-.5-.1-1.1-.3-1.6"></path></svg>
        Hurry! Only {{ product.selected_or_first_available_variant.inventory_quantity }} units left in stock!
      </div>
    {%- endif -%}

    {% comment %} Variant Data for JS {% endcomment %}
    <script type="application/json" id="naQvVariantData">
      {{ product.variants | json }}
    </script>
  </div>
</div>
