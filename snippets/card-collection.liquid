{% comment %}
  Renders a premium collection card (The Aura) with Multi-Image Slideshow
  Accepts:
  - card_collection: {Object} Collection Liquid object
{% endcomment %}

<div class="card-wrapper">
  <a href="{{ card_collection.url | default: '#' }}" class="na-collection-card">
    <div class="na-collection-image-wrapper">
      <div class="na-collection-slideshow">
        {%- if card_collection.products.size > 0 -%}
          {%- for product in card_collection.products limit: 3 -%}
            <img
              srcset="
                {%- if product.featured_image.width >= 165 -%}{{ product.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
                {%- if product.featured_image.width >= 330 -%}{{ product.featured_image | image_url: width: 330 }} 330w,{%- endif -%}
                {%- if product.featured_image.width >= 535 -%}{{ product.featured_image | image_url: width: 535 }} 535w,{%- endif -%}
                {%- if product.featured_image.width >= 750 -%}{{ product.featured_image | image_url: width: 750 }} 750w,{%- endif -%}
                {{ product.featured_image | image_url }} {{ product.featured_image.width }}w
              "
              src="{{ product.featured_image | image_url: width: 750 }}"
              sizes="(min-width: 1200px) 400px, (min-width: 750px) 33vw, 100vw"
              alt="{{ product.title | escape }}"
              height="{{ product.featured_image.height }}"
              width="{{ product.featured_image.width }}"
              loading="lazy"
              style="animation-delay: {{ forloop.index0 | times: 3 }}s"
            >
          {%- endfor -%}
        {%- elsif card_collection.featured_image -%}
          <img
            src="{{ card_collection.featured_image | image_url: width: 750 }}"
            alt="{{ card_collection.title | escape }}"
            height="{{ card_collection.featured_image.height }}"
            width="{{ card_collection.featured_image.width }}"
            loading="lazy"
            style="animation: none; opacity: 1;"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <div class="na-collection-info">
      <div class="na-collection-meta">
        {%- if card_collection.all_products_count > 0 -%}
          <span class="na-collection-count">{{ card_collection.all_products_count }} items</span>
        {%- endif -%}
      </div>
      <h3 class="na-collection-title">
        {%- if card_collection.title != blank -%}
          {{- card_collection.title | escape -}}
        {%- else -%}
          {{ 'onboarding.collection_title' | t }}
        {%- endif -%}
      </h3>
      <div class="na-collection-action">
        <span class="view-collection-text">View Collection</span>
        <span class="icon-wrap">
          {{- 'icon-arrow.svg' | inline_asset_content -}}
        </span>
      </div>
    </div>
  </a>
</div>
