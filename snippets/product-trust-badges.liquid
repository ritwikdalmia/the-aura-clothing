{% comment %}
  Renders brand trust badges for the product page.
  Mirroring the Aura cart drawer aesthetic.
{% endcomment %}
<div class="product-trust-badges aura-trust-badges">
  <div class="badge-item">
    <div class="badge-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
    </div>
    <div class="badge-text">
      <span class="badge-title">Free Shipping</span>
      <span class="badge-subtitle">On all orders over $150</span>
    </div>
  </div>

  <div class="badge-divider"></div>

  <div class="badge-item">
    <div class="badge-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
    </div>
    <div class="badge-text">
      <span class="badge-title">Secure Payment</span>
      <span class="badge-subtitle">100% Secure Checkout</span>
    </div>
  </div>
</div>
