{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'aura-customer-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  <div class="account-header">
    <h1>Order {{ order.name }}</h1>
    <p>Placed on {{ order.created_at | time_tag: format: 'date_at_time' }}</p>
  </div>

  <div class="customer account-container">
    <!-- Sidebar Navigation -->
    <aside class="account-nav">
      <ul class="account-nav-list">
        <li class="account-nav-item">
          <a href="{{ routes.account_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Dashboard
          </a>
        </li>
        <li class="account-nav-item">
          <a href="{{ routes.account_addresses_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            Addresses
          </a>
        </li>
        <li class="account-nav-item">
          <a href="{{ routes.account_logout_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Logout
          </a>
        </li>
      </ul>

      <div class="premium-form-card" style="margin-top: 3rem; padding: 2rem; text-align: left;">
        <h3 style="font-size: 1.4rem; margin-bottom: 1.5rem; text-transform: uppercase; color: var(--aura-gold);">Order Summary</h3>
        <div style="display: flex; justify-content: space-between; margin-bottom: 0.8rem;">
          <span>Status</span>
          <span class="status-badge {% if order.financial_status == 'paid' %}status-badge--success{% else %}status-badge--warning{% endif %}">
            {{ order.financial_status_label }}
          </span>
        </div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 0.8rem;">
          <span>Fulfillment</span>
          <span class="status-badge status-badge--info">{{ order.fulfillment_status_label }}</span>
        </div>
        <hr style="margin: 1.5rem 0; border: none; border-top: 1px solid #eee;">
        <div style="display: flex; justify-content: space-between; font-weight: 700; font-size: 1.6rem; color: var(--aura-gold);">
          <span>Total</span>
          <span>{{ order.total_net_amount | money_with_currency }}</span>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="account-content">
      {%- if order.cancelled -%}
        <div class="premium-form-card" style="background: #fff5f5; border-color: #feb2b2; margin-bottom: 3rem; text-align: left;">
          {%- assign cancelled_at = order.cancelled_at | time_tag: format: 'date_at_time' -%}
          <h2 style="color: #c53030; font-size: 1.8rem; margin-bottom: 0.5rem;">Order Cancelled</h2>
          <p style="color: #9b2c2c;">{{ 'customer.order.cancelled_html' | t: date: cancelled_at }}</p>
          <p style="color: #9b2c2c;">Reason: {{ order.cancel_reason_label }}</p>
        </div>
      {%- endif -%}

      <div class="premium-form-card" style="text-align: left; padding: 3rem;">
        <h2 style="font-size: 2rem; margin-bottom: 2.5rem; text-transform: uppercase; letter-spacing: 0.1em;">Items Ordered</h2>
        
        <table role="table" class="order-details" style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 1px solid #eee;">
              <th style="padding: 1.5rem 0; text-align: left; font-size: 1.2rem; text-transform: uppercase; color: #888;">Product</th>
              <th style="padding: 1.5rem 0; text-align: right; font-size: 1.2rem; text-transform: uppercase; color: #888;">Price</th>
              <th style="padding: 1.5rem 0; text-align: right; font-size: 1.2rem; text-transform: uppercase; color: #888;">Qty</th>
              <th style="padding: 1.5rem 0; text-align: right; font-size: 1.2rem; text-transform: uppercase; color: #888;">Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for line_item in order.line_items -%}
              <tr style="border-bottom: 1px solid #f9f9f9;">
                <td style="padding: 2rem 0;">
                  <div style="display: flex; gap: 1.5rem; align-items: center;">
                    <div style="width: 60px; height: 80px; background: #f5f5f5; border-radius: 4px; overflow: hidden;">
                      {% if line_item.image %}
                        <img src="{{ line_item.image | image_url: width: 120 }}" alt="{{ line_item.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag }}
                      {% endif %}
                    </div>
                    <div>
                      <a href="{{ line_item.url }}" style="font-weight: 600; color: var(--brand-dark); text-decoration: none;">{{ line_item.title | escape }}</a>
                      {%- unless line_item.product.has_only_default_variant -%}
                        <p style="font-size: 1.2rem; color: #888; margin-top: 0.4rem;">{{ line_item.variant.title }}</p>
                      {%- endunless -%}
                      {%- if line_item.fulfillment -%}
                        <div style="margin-top: 1rem; font-size: 1.1rem;">
                          <span class="status-badge status-badge--success">Fulfilled</span>
                          {%- if line_item.fulfillment.tracking_url -%}
                            <a href="{{ line_item.fulfillment.tracking_url }}" style="margin-left: 1rem; color: var(--aura-gold);">Track Item</a>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </td>
                <td style="padding: 2rem 0; text-align: right;">{{ line_item.original_price | money }}</td>
                <td style="padding: 2rem 0; text-align: right;">{{ line_item.quantity }}</td>
                <td style="padding: 2rem 0; text-align: right; font-weight: 600;">{{ line_item.final_line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
          <tfoot>
            <tr>
              <td colspan="3" style="padding: 1.5rem 0 0.5rem; text-align: right; color: #888;">Subtotal</td>
              <td style="padding: 1.5rem 0 0.5rem; text-align: right;">{{ order.line_items_subtotal_price | money }}</td>
            </tr>
            {%- for shipping_method in order.shipping_methods -%}
              <tr>
                <td colspan="3" style="padding: 0.5rem 0; text-align: right; color: #888;">Shipping ({{ shipping_method.title }})</td>
                <td style="padding: 0.5rem 0; text-align: right;">{{ shipping_method.price | money }}</td>
              </tr>
            {%- endfor -%}
            {%- for tax_line in order.tax_lines -%}
              <tr>
                <td colspan="3" style="padding: 0.5rem 0; text-align: right; color: #888;">Tax ({{ tax_line.title }} {{ tax_line.rate | times: 100 }}%)</td>
                <td style="padding: 0.5rem 0; text-align: right;">{{ tax_line.price | money }}</td>
              </tr>
            {%- endfor -%}
            <tr>
              <td colspan="3" style="padding: 1.5rem 0 0; text-align: right; font-weight: 700; font-size: 1.8rem; color: var(--brand-dark);">Total</td>
              <td style="padding: 1.5rem 0 0; text-align: right; font-weight: 700; font-size: 1.8rem; color: var(--aura-gold);">{{ order.total_net_amount | money_with_currency }}</td>
            </tr>
          </tfoot>
        </table>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 3rem;">
        <div class="premium-form-card" style="text-align: left;">
          <h3 style="font-size: 1.6rem; margin-bottom: 1.5rem; text-transform: uppercase;">Billing Address</h3>
          {{ order.billing_address | format_address }}
        </div>
        <div class="premium-form-card" style="text-align: left;">
          <h3 style="font-size: 1.6rem; margin-bottom: 1.5rem; text-transform: uppercase;">Shipping Address</h3>
          {{ order.shipping_address | format_address }}
        </div>
      </div>
    </main>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-order.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
