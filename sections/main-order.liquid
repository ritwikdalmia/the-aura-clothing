<style>
  .order-page {
    max-width: 900px;
    margin: 60px auto;
    padding: 0 20px;
    font-family: var(--font-body-family);
    color: #1a1a1a;
  }

  .order-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 20px;
  }

  .order-header h1 {
    font-size: 24px;
    font-weight: 600;
    margin: 0;
  }

  .order-status-badge {
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    text-transform: capitalize;
    background: #f0fdf4;
    color: #16a34a;
    border: 1px solid #bbf7d0;
  }

  .order-status-badge.unfulfilled {
    background: #fff7ed;
    color: #ea580c;
    border-color: #fed7aa;
  }

  .order-status-badge.cancelled {
    background: #fef2f2;
    color: #dc2626;
    border-color: #fecaca;
  }

  .order-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
  }

  @media (max-width: 768px) {
    .order-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Line Items */
  .order-items-card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .order-items-card h2 {
    font-size: 15px;
    font-weight: 600;
    padding: 16px 20px;
    margin: 0;
    border-bottom: 1px solid #e5e5e5;
    background: #fafafa;
  }

  .line-item {
    display: flex;
    gap: 16px;
    padding: 16px 20px;
    border-bottom: 1px solid #f0f0f0;
    align-items: center;
  }

  .line-item:last-child {
    border-bottom: none;
  }

  .line-item img {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
  }

  .line-item-placeholder {
    width: 72px;
    height: 72px;
    background: #f5f5f5;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 11px;
  }

  .line-item-details {
    flex: 1;
  }

  .line-item-details .product-title {
    font-weight: 500;
    font-size: 14px;
    margin-bottom: 4px;
  }

  .line-item-details .variant-title {
    font-size: 13px;
    color: #666;
    margin-bottom: 4px;
  }

  .line-item-details .quantity {
    font-size: 13px;
    color: #888;
  }

  .line-item-price {
    font-weight: 600;
    font-size: 14px;
    white-space: nowrap;
  }

  /* Summary Card */
  .order-summary-card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
  }

  .order-summary-card h2 {
    font-size: 15px;
    font-weight: 600;
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #e5e5e5;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    margin-bottom: 10px;
    color: #444;
  }

  .summary-row.total {
    font-weight: 700;
    font-size: 16px;
    color: #1a1a1a;
    border-top: 1px solid #e5e5e5;
    padding-top: 12px;
    margin-top: 4px;
  }

  /* Address Cards */
  .address-card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
  }

  .address-card h2 {
    font-size: 15px;
    font-weight: 600;
    margin: 0 0 12px;
  }

  .address-card address {
    font-style: normal;
    font-size: 14px;
    line-height: 1.7;
    color: #444;
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: #555;
    text-decoration: none;
    margin-bottom: 24px;
  }

  .back-link:hover {
    color: #000;
  }
</style>

<div class="order-page">

  <a href="{{ routes.account_url }}" class="back-link">
    ← Back to Account
  </a>

  <div class="order-header">
    <h1>Order {{ order.name }}</h1>
    <span class="order-status-badge {{ order.fulfillment_status }}">
      {{ order.fulfillment_status_label }}
    </span>
  </div>

  <p style="color:#888; font-size:14px; margin-top:-20px; margin-bottom:28px;">
    Placed on {{ order.created_at | date: "%B %d, %Y" }}
  </p>

  <div class="order-grid">

    <!-- LEFT COLUMN -->
    <div>

      <!-- Line Items -->
      <div class="order-items-card">
        <h2>Items Ordered</h2>
        {% for line_item in order.line_items %}
          <div class="line-item">
            {% if line_item.image %}
              <img src="{{ line_item.image | img_url: '150x150' }}" alt="{{ line_item.title }}">
            {% else %}
              <div class="line-item-placeholder">No image</div>
            {% endif %}
            <div class="line-item-details">
              <div class="product-title">{{ line_item.title }}</div>
              {% unless line_item.variant_title == 'Default Title' %}
                <div class="variant-title">{{ line_item.variant_title }}</div>
              {% endunless %}
              <div class="quantity">Qty: {{ line_item.quantity }}</div>
            </div>
            <div class="line-item-price">
              {{ line_item.final_line_price | money }}
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Shipping Address -->
      {% if order.shipping_address %}
        <div class="address-card">
          <h2>Shipping Address</h2>
          <address>
            {{ order.shipping_address.name }}<br>
            {{ order.shipping_address.address1 }}<br>
            {% if order.shipping_address.address2 != blank %}
              {{ order.shipping_address.address2 }}<br>
            {% endif %}
            {{ order.shipping_address.city }}, {{ order.shipping_address.province }} {{ order.shipping_address.zip }}<br>
            {{ order.shipping_address.country }}
          </address>
        </div>
      {% endif %}

    </div>

    <!-- RIGHT COLUMN -->
    <div>

      <!-- Order Summary -->
      <div class="order-summary-card">
        <h2>Order Summary</h2>
        <div class="summary-row">
          <span>Subtotal</span>
          <span>{{ order.subtotal_price | money }}</span>
        </div>
        <div class="summary-row">
          <span>Shipping</span>
          <span>{{ order.shipping_price | money }}</span>
        </div>
        {% if order.tax_price > 0 %}
          <div class="summary-row">
            <span>Taxes</span>
            <span>{{ order.tax_price | money }}</span>
          </div>
        {% endif %}
        <div class="summary-row total">
          <span>Total</span>
          <span>{{ order.total_price | money }}</span>
        </div>
      </div>

      <!-- Billing Address -->
      {% if order.billing_address %}
        <div class="address-card">
          <h2>Billing Address</h2>
          <address>
            {{ order.billing_address.name }}<br>
            {{ order.billing_address.address1 }}<br>
            {% if order.billing_address.address2 != blank %}
              {{ order.billing_address.address2 }}<br>
            {% endif %}
            {{ order.billing_address.city }}, {{ order.billing_address.province }} {{ order.billing_address.zip }}<br>
            {{ order.billing_address.country }}
          </address>
        </div>
      {% endif %}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Order",
  "settings": []
}
{% endschema %}
