{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ============================
     Best Seller Carousel
     ============================ */

  .bs-section-bg {
    background: transparent;
    position: relative;
    overflow: hidden;
  }

  .bs-section-bg::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(ellipse, rgba(var(--aura-brand-gold-rgb), 0.04) 0%, transparent 65%);
    pointer-events: none;
  }

  .bs-section-bg::after {
    content: '';
    position: absolute;
    bottom: -30%;
    right: -15%;
    width: 50%;
    height: 160%;
    background: radial-gradient(ellipse, rgba(var(--aura-brand-gold-rgb), 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .bs-wide-container {
    max-width: 160rem;
    margin: 0 auto;
    padding-left: 2.5rem;
    padding-right: 2.5rem;
  }

  @media screen and (min-width: 750px) {
    .bs-wide-container {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  /* Section Header */
  .bs-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .bs-header::after {
    content: '';
    display: block;
    width: 80px;
    height: 1px;
    background: var(--aura-brand-gold);
    margin: 1.4rem auto 0;
  }

  .bs-subtitle {
    font-size: var(--aura-font-size-xs);
    color: var(--aura-brand-gold);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: var(--aura-font-weight-medium);
    margin-bottom: 0.4rem;
  }

  .bs-title {
    font-size: var(--aura-font-size-lg);
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-weight: var(--aura-font-weight-light);
    font-family: var(--font-heading-family);
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .bs-title {
      font-size: 3.4rem;
    }
  }

  /* ===== Carousel ===== */
  .bs-carousel-wrapper {
    position: relative;
    padding: 0 45px;
  }

  .bs-carousel-track {
    display: flex;
    gap: 2rem;
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 1.5rem 1rem 2rem;
    margin: -1.5rem 0 -2rem;
    scroll-behavior: smooth;
  }

  .bs-carousel-track::-webkit-scrollbar {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .bs-carousel-track {
      gap: 2.4rem;
      padding: 1.5rem 0.5rem 2rem;
      margin: -1.5rem -0.5rem -2rem;
    }
  }

  /* Carousel Arrows */
  .bs-arrow {
    position: absolute;
    top: 45%;
    transform: translateY(-50%);
    z-index: 10;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--aura-overlay-white-heavy);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(0,0,0,0.06);
    box-shadow: 0 4px 14px var(--aura-overlay-dark);
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .bs-arrow:hover {
    transform: translateY(-50%) scale(1.1);
    box-shadow: 0 6px 18px var(--aura-overlay-dark-medium);
  }

  .bs-arrow--prev { left: -40px; }
  .bs-arrow--next { right: -40px; }

  .bs-arrow svg {
    width: 18px;
    height: 18px;
    stroke: var(--aura-color-text-medium);
    stroke-width: 2.5;
    fill: none;
  }

  @media screen and (min-width: 750px) {
    .bs-arrow { display: flex; }
  }

  /* ===== Product Card (matches new-arrivals-premium) ===== */
  .bs-product-card {
    flex: 0 0 230px;
    scroll-snap-align: start;
    position: relative;
    will-change: transform;
    display: flex;
    flex-direction: column;
  }

  @media screen and (min-width: 750px) {
    .bs-product-card {
      flex: 0 0 280px;
    }
  }

  @media screen and (min-width: 990px) {
    .bs-product-card {
      flex: 0 0 300px;
    }
  }

  /* ===== 3D Product Card — Consolidated to component-card.css ===== */

  /* ===== Glassmorphism Badges ===== */
  .bs-badge-container {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }

  .bs-badge {
    padding: 5px 14px;
    font-size: 1rem;
    font-weight: var(--aura-font-weight-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: var(--aura-radius-sm);
    line-height: 1.4;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 8px var(--aura-overlay-dark);
  }

  .bs-badge--bestseller {
    background: rgba(var(--aura-brand-gold-rgb), 0.85);
    color: var(--aura-white);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .bs-badge--sale {
    background: var(--aura-brand-sale);
    color: var(--aura-white);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .bs-badge--new {
    background: var(--aura-color-badge-dark);
    color: var(--aura-white);
    border: 1px solid var(--aura-overlay-white-subtle);
  }

  .bs-badge--best {
    background: rgba(var(--aura-brand-gold-rgb), 0.85);
    color: var(--aura-white);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .bs-badge--sold-out {
    background: rgba(var(--color-background), 0.8);
    color: rgb(var(--color-foreground));
    border: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .bs-wishlist, .bs-compare {
    position: absolute;
    right: 12px;
    z-index: 5;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--aura-overlay-white);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 50%;
    border: 1px solid var(--aura-overlay-white-subtle);
    cursor: pointer;
    opacity: 1; /* Always visible as per user request */
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 12px var(--aura-overlay-dark);
    transform: scale(1) rotate(0deg);
  }

  .bs-wishlist {
    top: 12px;
  }

  .bs-compare {
    top: 58px;
  }

  .bs-wishlist svg, .bs-compare svg {
    width: 16px;
    height: 16px;
    stroke: var(--aura-color-text-medium);
    fill: none;
    stroke-width: 1.8;
    transition: fill 0.2s ease, stroke 0.2s ease;
  }

  .bs-wishlist:hover:not(.is-active) svg, .bs-compare:hover:not(.is-active) svg {
    stroke: var(--aura-brand-gold);
    fill: none;
  }

  .bs-wishlist:hover:not(.is-active), .bs-compare:hover:not(.is-active) {
    background: var(--aura-white);
    transform: scale(1.1) !important;
    box-shadow: 0 6px 16px var(--aura-overlay-dark);
  }

  .bs-wishlist.is-active, .bs-compare.is-active {
    background: var(--aura-brand-gold) !important;
    border-color: var(--aura-brand-gold) !important;
    color: var(--aura-white) !important;
  }

  .bs-wishlist.is-active svg, .bs-compare.is-active svg {
    fill: currentColor !important;
    stroke: currentColor !important;
  }

  /* Quick Add — premium gold styling */
  .bs-quick-add {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 5;
    background: var(--aura-overlay-white-heavy);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--aura-brand-dark);
    text-align: center;
    padding: 16px;
    font-size: var(--aura-font-size-xs);
    font-weight: var(--aura-font-weight-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    border: none;
    border-top: 1px solid rgba(var(--aura-brand-gold-rgb), 0.15);
    transform: translateY(100%);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .bs-quick-add:hover {
    background: var(--aura-brand-gold);
    color: var(--aura-white);
  }

  .bs-product-card:hover .bs-quick-add {
    transform: translateY(0);
  }

  /* Card Info */
  .bs-card-info {
    padding: 1.5rem 1.4rem 1.8rem;
    background: var(--aura-white);
    display: flex;
    flex-direction: column;
    flex: 1;
    text-align: left;
    align-items: flex-start;
  }

  .bs-card-title {
    font-size: 1.5rem;
    font-weight: var(--aura-font-weight-medium);
    color: var(--aura-brand-dark);
    margin: 0 0 0.5rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
    text-align: left;
  }

  .bs-card-price-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .bs-card-price {
    font-size: 1.3rem;
    font-weight: var(--aura-font-weight-bold);
    color: var(--aura-brand-gold);
  }

  .bs-card-compare-price {
    font-size: var(--aura-font-size-xs);
    color: var(--aura-black); /* Match product page strikethrough color */
    text-decoration: line-through;
    opacity: 0.6;
  }

  .bs-card-discount-val {
    font-size: var(--aura-font-size-xs);
    font-weight: var(--aura-font-weight-bold);
    color: var(--aura-brand-sale);
    margin-top: 4px;
  }

  /* Responsive Adjustments */
  @media screen and (max-width: 749px) {
    .bs-wishlist, .bs-compare {
      width: 32px;
      height: 32px;
      right: 8px;
    }
    .bs-wishlist { top: 8px; }
    .bs-compare { top: 46px; }
    
    .bs-badge {
      font-size: 0.9rem;
      padding: 4px 8px;
      left: 8px;
      top: 8px;
    }

    .bs-card-info {
      padding: 1rem 1rem 1.2rem;
    }

    .bs-card-title {
      font-size: 1.2rem;
    }
    
    .bs-card-price {
      font-size: 1.3rem;
    }
  }

  @media screen and (max-width: 320px) {
    .bs-wishlist, .bs-compare {
      width: 28px !important;
      height: 28px !important;
    }
    .bs-compare { top: 40px !important; }
    
    .bs-card-title {
      font-size: 1.15rem !important;
    }
    
    .bs-card-price {
      font-size: 1.25rem !important;
    }

    .bs-badge {
      font-size: 0.8rem !important;
      padding: 3px 6px !important;
    }
  }

  /* View All Button */
  .bs-view-all-wrapper {
    text-align: center;
    margin-top: 3.5rem;
  }

  .na-view-all-btn {
    display: inline-block;
    padding: 14px 42px;
    border: 1px solid var(--aura-brand-gold);
    border-radius: var(--aura-radius-pill);
    color: var(--aura-brand-dark);
    font-size: var(--aura-font-size-xs);
    font-weight: var(--aura-font-weight-semibold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: color 0.4s ease, transform 0.3s ease, box-shadow 0.3s ease;
    z-index: 1;
  }

  .na-view-all-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--aura-brand-gold);
    transition: left 0.4s ease;
    z-index: -1;
  }

  .na-view-all-btn:hover::before {
    left: 0;
  }

  .na-view-all-btn:hover {
    color: var(--aura-white);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(var(--aura-brand-gold-rgb), 0.25);
  }

  /* Auto-scroll pause on hover */
  .bs-carousel-track.is-paused {
    animation-play-state: paused !important;
  }

  @media screen and (max-width: 749px) {
    .bs-carousel-wrapper {
      padding: 0 20px;
    }
    .bs-product-card {
      flex: 0 0 82%; /* Ensures one full card and a peek of the next */
    }
    .bs-card-image-wrapper {
      aspect-ratio: 3 / 4 !important;
    }
    .bs-badge {
      padding: 3px 10px;
      font-size: 0.85rem;
      top: 10px;
      left: 10px;
    }
    .bs-wishlist {
      width: 30px;
      height: 30px;
      right: 10px;
      top: 10px;
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
    .bs-wishlist svg {
      width: 14px;
      height: 14px;
    }
     .bs-quick-add {
      transform: translateY(0);
      padding: 8px 12px;
      font-size: 0.85rem;
      background: var(--aura-overlay-white-heavy);
      color: var(--aura-brand-dark);
    }
    .bs-card-info {
      padding: 0.8rem 1rem;
    }
    .bs-card-title {
      font-size: 1.1rem;
    }
  }

{%- endstyle -%}

{%- liquid
  assign dummy_products = "Floral Summer Maxi Dress,Leopard Print Co-ord Set,Elegant Black Bodycon Dress,Cherry Blossom Wrap Top,Pastel Blue Skater Dress,Premium Velvet Evening Gown,Boho Tiered Ruffle Skirt,Classic White Linen Blouse" | split: ","
  assign dummy_prices = "2499,3199,1899,1599,2799,4999,2199,1299" | split: ","
  assign dummy_compare = "4999,5499,3799,2999,4599,8999,3999,2499" | split: ","
  assign dummy_has_sale = "true,false,true,false,false,true,false,true" | split: ","
  assign placeholders = "product-1,product-2,product-3,product-4,product-5,product-6,product-1,product-2" | split: ","
  assign dummy_discounts = "50,0,50,0,0,44,0,48" | split: ","
  assign products_to_show = section.settings.products_to_show | default: 8
-%}

{%- if section.settings.collection != blank and section.settings.collection.all_products_count > 0 or request.design_mode -%}
<div class="bs-section-bg color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="bs-wide-container">
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="bs-header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if section.settings.subtitle != blank -%}
          <p class="bs-subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="bs-title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="bs-carousel-wrapper">
      <button class="bs-arrow bs-arrow--prev" aria-label="Previous" data-bs-prev>
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="bs-arrow bs-arrow--next" aria-label="Next" data-bs-next>
        <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
      </button>

      <div class="bs-carousel-track" data-bs-track>
        {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
          {%- assign products_count = 0 -%}
          {%- for product in section.settings.collection.products -%}
            {%- if section.settings.filter_on_sale and product.compare_at_price <= product.price -%}
              {%- continue -%}
            {%- endif -%}
            {%- assign products_count = products_count | plus: 1 -%}
            <a href="{{ product.url }}" class="bs-product-card" style="animation-delay: {{ products_count | times: 80 }}ms;">
              <div class="bs-card-image-wrapper">
                <div class="bs-badge-container">
                  {%- liquid
                    assign date_now = 'now' | date: '%s'
                    assign date_published = product.published_at | date: '%s'
                    assign diff_seconds = date_now | minus: date_published
                    assign is_new = false
                    if diff_seconds < 2592000
                      assign is_new = true
                    endif
                  -%}
                  {%- if product.compare_at_price > product.price -%}
                    {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                    <span class="bs-badge bs-badge--sale">-{{ savings }}% SALE</span>
                  {%- elsif is_new or product.tags contains 'new' or product.tags contains 'New' -%}
                    <span class="bs-badge bs-badge--new">New</span>
                  {%- endif -%}
                  {%- if product.available == false -%}
                    <span class="bs-badge bs-badge--sold-out">Sold Out</span>
                  {%- endif -%}
                </div>
                <button class="bs-wishlist" aria-label="Add to wishlist" data-aura-wishlist="{{ product.handle }}">
                  <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </button>
                <button class="bs-compare" aria-label="Add to compare" data-aura-compare="{{ product.handle }}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"></polyline><line x1="4" y1="20" x2="21" y2="3"></line><polyline points="21 16 21 21 16 21"></polyline><line x1="15" y1="15" x2="21" y2="21"></line><line x1="4" y1="4" x2="9" y2="9"></line></svg>
                </button>
                {%- if product.featured_media -%}
                  <img class="bs-card-img-primary" src="{{ product.featured_media | image_url: width: 600 }}" alt="{{ product.featured_media.alt | escape }}" loading="lazy" width="600" height="800">
                  {%- if product.media[1] -%}
                    <img class="bs-card-img-hover" src="{{ product.media[1] | image_url: width: 600 }}" alt="{{ product.media[1].alt | escape }}" loading="lazy" width="600" height="800">
                  {%- endif -%}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'bs-card-img-primary' }}
                {%- endif -%}
                {%- if product.available -%}
                  <div class="bs-quick-add" onclick="event.preventDefault(); event.stopPropagation(); openQuickAdd('{{ product.url }}', this)">Quick Add</div>
                {%- endif -%}
              </div>
              <div class="bs-card-info">
                <h3 class="bs-card-title">{{ product.title }}</h3>
                
                <div class="bs-card-price-row">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="bs-card-compare-price">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                  <span class="bs-card-price">
                    {%- if product.price_varies -%}
                      {%- assign price = product.price | money -%}
                      {{ 'products.product.price.from_price_html' | t: price: price }}
                    {%- else -%}
                      {{ product.price | money }}
                    {%- endif -%}
                  </span>
                </div>

                <div class="na-mobile-actions">
                  <button class="na-wishlist-mobile" aria-label="Add to wishlist" data-aura-wishlist="{{ product.handle }}">
                    <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  </button>
                  <button class="na-compare-mobile" aria-label="Add to compare" data-aura-compare="{{ product.handle }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"></polyline><line x1="4" y1="20" x2="21" y2="3"></line><polyline points="21 16 21 21 16 21"></polyline><line x1="15" y1="15" x2="21" y2="21"></line><line x1="4" y1="4" x2="9" y2="9"></line></svg>
                  </button>
                </div>
              </div>
            </a>
            {%- if products_count >= products_to_show -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
        {%- elsif request.design_mode -%}
          {%- for i in (1..8) -%}
            {%- assign idx = forloop.index0 -%}
            <div class="bs-product-card" style="animation-delay: {{ forloop.index | times: 80 }}ms;">
              <div class="bs-card-image-wrapper">
                {%- if dummy_has_sale[idx] == 'true' -%}
                  <span class="bs-badge bs-badge--sale">-{{ dummy_discounts[idx] }}% SALE</span>
                {%- elsif idx < 3 -%}
                  <span class="bs-badge bs-badge--new">NEW</span>
                {%- endif -%}
                <button class="bs-wishlist" aria-label="Add to wishlist">
                  <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </button>
                {{ placeholders[idx] | placeholder_svg_tag: 'bs-card-img-primary' }}
                <div class="bs-rank">{{ forloop.index }}</div>
                <div class="bs-quick-add">Quick Add</div>
              </div>
              <div class="bs-card-info">
                  <h3 class="bs-card-title">{{ dummy_products[idx] }}</h3>
                  <div class="bs-card-price-row">
                  {%- if dummy_has_sale[idx] == 'true' -%}
                    <span class="bs-card-compare-price">{{ cart.currency.symbol }}{{ dummy_compare[idx] }}</span>
                  {%- endif -%}
                  <span class="bs-card-price">{{ cart.currency.symbol }}{{ dummy_prices[idx] }}</span>
                </div>
                <div class="na-mobile-actions">
                  <button class="na-wishlist-mobile" aria-label="Add to wishlist">
                    <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  </button>
                  <button class="na-compare-mobile" aria-label="Add to compare">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"></polyline><line x1="4" y1="20" x2="21" y2="3"></line><polyline points="21 16 21 21 16 21"></polyline><line x1="15" y1="15" x2="21" y2="21"></line><line x1="4" y1="4" x2="9" y2="9"></line></svg>
                  </button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_view_all -%}
      <div class="na-view-all-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a href="{{ section.settings.view_all_link | default: routes.all_products_collection_url }}" class="na-view-all-btn">
          {{ section.settings.view_all_text | default: 'View All' | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>
{%- endif -%}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.bs-carousel-wrapper').forEach(function (wrapper) {
      var track = wrapper.querySelector('[data-bs-track]');
      var prevBtn = wrapper.querySelector('[data-bs-prev]');
      var nextBtn = wrapper.querySelector('[data-bs-next]');
      if (!track) return;

      var cardWidth = 320;
      var autoScrollInterval;
      var scrollSpeed = {{ section.settings.auto_scroll_speed | default: 4 }} * 1000;

      function scrollNext() {
        var maxScroll = track.scrollWidth - track.clientWidth;
        if (track.scrollLeft >= maxScroll - 10) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: cardWidth, behavior: 'smooth' });
        }
      }

      function startAutoScroll() {
        if (scrollSpeed > 0) {
          autoScrollInterval = setInterval(scrollNext, scrollSpeed);
        }
      }

      function stopAutoScroll() {
        clearInterval(autoScrollInterval);
      }

      startAutoScroll();

      track.addEventListener('mouseenter', stopAutoScroll);
      track.addEventListener('mouseleave', startAutoScroll);
      track.addEventListener('touchstart', stopAutoScroll, { passive: true });
      track.addEventListener('touchend', function () {
        setTimeout(startAutoScroll, 3000);
      });

      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          stopAutoScroll();
          track.scrollBy({ left: -cardWidth, behavior: 'smooth' });
          setTimeout(startAutoScroll, 5000);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          stopAutoScroll();
          scrollNext();
          setTimeout(startAutoScroll, 5000);
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Best Sellers Carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Best Sellers",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "Top Picks",
      "label": "Subtitle"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave empty to show placeholder products"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "filter_on_sale",
      "label": "Only show products on sale",
      "default": false,
      "info": "If checked, only products with a compare-at price will be shown."
    },
    {
      "type": "range",
      "id": "auto_scroll_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "unit": "s",
      "label": "Auto-scroll speed (seconds)"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show 'View All' button"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "default": "View All Best Sellers",
      "label": "View All button text"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Best Sellers Carousel"
    }
  ]
}
{% endschema %}
