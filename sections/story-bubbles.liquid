{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Premium Story Circles Styling */
  .story-circles-container {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    overflow: visible;
    padding: 0 40px; /* Space for buttons outside wrapper content */
  }

  .story-circles-wrapper {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 15px;
    padding: 20px 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
    flex: 1;
    justify-content: flex-start;
  }
  
  .story-circles-wrapper::-webkit-scrollbar {
    display: none;
  }

  .story-nav-button {
    background: white;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    z-index: 10;
    transition: all 0.3s ease;
    padding: 0;
  }

  .story-nav-prev { left: 0; }
  .story-nav-next { right: 0; }

  .story-nav-button:hover {
    background: #f8f8f8;
    transform: translateY(-50%) scale(1.1);
  }

  .story-nav-button svg { width: 20px; height: 20px; fill: #333; }

  .story-circle-item {
    scroll-snap-align: start;
    flex: 0 0 90px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .story-circle-image-container {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    padding: 2px;
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    margin-bottom: 10px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0,0,0,0.08);
    transition: transform 0.3s ease;
  }

  .story-circle-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid #ffffff;
    display: block;
  }

  .story-circle-title {
    font-size: 1rem;
    color: #444;
    text-align: center;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    width: 100%;
    line-height: 1.2;
    overflow-wrap: break-word;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .story-circles-container {
      padding: 0 60px; /* Even more space on desktop */
    }
    .story-circles-wrapper {
      gap: 30px;
      padding: 30px 0;
      justify-content: center;
    }
    .story-circle-item {
      flex: 0 0 110px;
    }
    .story-circle-image-container {
      width: 100px;
      height: 100px;
    }
    .story-circle-title {
      font-size: 1.1rem;
    }
    .story-nav-button {
      width: 44px;
      height: 44px;
    }
  }

  @media screen and (max-width: 749px) {
    .story-nav-button { display: none; }
    .story-circles-container { padding: 0 15px; }
    .story-circles-wrapper { padding: 15px 0; }
  }

  .story-circle-item:hover { transform: translateY(-5px); }
  .story-circle-item:hover .story-circle-image-container { transform: scale(1.05); }
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-family: var(--font-heading-family);
  }

{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="story-circles-container">
      <button class="story-nav-button story-nav-prev" aria-label="Previous" onclick="this.parentElement.querySelector('.story-circles-wrapper').scrollBy({left: -200, behavior: 'smooth'})">
        <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      </button>

      <div class="story-circles-wrapper">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="story-circle-item" {{ block.shopify_attributes }}>
            <div class="story-circle-image-container">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 200 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  class="story-circle-image"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'story-circle-image placeholder-svg' }}
              {%- endif -%}
            </div>
            {%- if block.settings.title != blank -%}
              <span class="story-circle-title">{{ block.settings.title | escape }}</span>
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>

      <button class="story-nav-button story-nav-next" aria-label="Next" onclick="this.parentElement.querySelector('.story-circles-wrapper').scrollBy({left: 200, behavior: 'smooth'})">
        <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
  /* Optional: Show/Hide arrows based on scroll position */
  document.addEventListener('DOMContentLoaded', function() {
    const wrappers = document.querySelectorAll('.story-circles-wrapper');
    wrappers.forEach(wrapper => {
      const container = wrapper.parentElement;
      const prevBtn = container.querySelector('.story-nav-prev');
      const nextBtn = container.querySelector('.story-nav-next');

      const updateArrows = () => {
        if (wrapper.scrollLeft <= 0) {
          prevBtn.style.opacity = '0.3';
          prevBtn.style.pointerEvents = 'none';
        } else {
          prevBtn.style.opacity = '1';
          prevBtn.style.pointerEvents = 'auto';
        }

        if (wrapper.scrollLeft + wrapper.clientWidth >= wrapper.scrollWidth - 1) {
          nextBtn.style.opacity = '0.3';
          nextBtn.style.pointerEvents = 'none';
        } else {
          nextBtn.style.opacity = '1';
          nextBtn.style.pointerEvents = 'auto';
        }
      };

      wrapper.addEventListener('scroll', updateArrows);
      window.addEventListener('resize', updateArrows);
      updateArrows();
    });
  });
</script>

{% schema %}
{
  "name": "Story Quick Links",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Quick Links",
      "blocks": [
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        }
      ]
    }
  ]
}
{% endschema %}
