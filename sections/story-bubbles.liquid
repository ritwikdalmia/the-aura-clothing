{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Premium Story Circles Styling */
  .story-circles-wrapper {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 20px;
    padding: 10px 20px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  
  .story-circles-wrapper::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }

  .story-circle-item {
    scroll-snap-align: start;
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    width: 80px;
    transition: transform 0.3s ease;
  }

  @media screen and (min-width: 750px) {
    .story-circles-wrapper {
      justify-content: center;
      gap: 40px;
      padding: 20px 0;
    }
    .story-circle-item {
      width: 100px;
    }
  }

  .story-circle-item:hover {
    transform: translateY(-5px);
  }

  .story-circle-image-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); /* Instagram style ring, can be customized */
    margin-bottom: 8px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    transition: box-shadow 0.3s ease, padding 0.3s ease;
  }

  .story-circle-item:hover .story-circle-image-container {
    box-shadow: 0 8px 15px rgba(0,0,0,0.15);
    padding: 0px; /* Expands image slightly */
  }

  .story-circle-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid #ffffff;
    display: block;
    transition: transform 0.3s ease;
  }

  .story-circle-item:hover .story-circle-image {
    transform: scale(1.05);
  }

  .story-circle-title {
    font-size: 1.2rem;
    color: rgb(var(--color-foreground));
    text-align: center;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-family: var(--font-heading-family);
  }

{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="story-circles-wrapper">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="story-circle-item" {{ block.shopify_attributes }}>
          <div class="story-circle-image-container">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 200 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="story-circle-image"
                loading="lazy"
                width="200"
                height="200"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'story-circle-image placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <span class="story-circle-title">{{ block.settings.title | escape }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Story Quick Links",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Quick Links",
      "blocks": [
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        }
      ]
    }
  ]
}
{% endschema %}
