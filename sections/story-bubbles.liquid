{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Premium Story Circles Styling */
  .story-circles-wrapper {
    display: flex;
    overflow-x: auto;
    overflow-y: visible; /* Prevents box-shadow/hover animations from getting cut vertically */
    scroll-snap-type: x mandatory;
    gap: 20px;
    padding: 20px; /* Adding horizontal padding so items don't stick directly to edges */
    -webkit-overflow-scrolling: touch;
    /* Soft visual scrollbar instead of completely hidden to help desktop users know they can scroll */
    scrollbar-width: thin;
    scrollbar-color: rgba(var(--color-foreground), 0.1) transparent;
  }
  
  .story-circles-wrapper::-webkit-scrollbar {
    height: 6px;
  }
  .story-circles-wrapper::-webkit-scrollbar-track {
    background: transparent;
  }
  .story-circles-wrapper::-webkit-scrollbar-thumb {
    background-color: rgba(var(--color-foreground), 0.15);
    border-radius: 10px;
  }

  .story-circle-item {
    scroll-snap-align: start;
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-decoration: none;
    width: 80px;
    transition: transform 0.3s ease;
  }

  @media screen and (min-width: 750px) {
    .story-circles-wrapper {
      /* justify-content: center; <-- THIS was causing the items to cut off on both sides when overflowing */
      gap: 40px;
      padding: 20px 40px;
    }
    .story-circle-item {
      width: 100px;
    }
  }

  .story-circle-item:hover {
    transform: translateY(-5px);
  }

  .story-circle-image-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); /* Instagram style ring, can be customized */
    margin-bottom: 8px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    transition: box-shadow 0.3s ease, padding 0.3s ease;
  }

  .story-circle-item:hover .story-circle-image-container {
    box-shadow: 0 8px 15px rgba(0,0,0,0.15);
    padding: 0px; /* Expands image slightly */
  }

  .story-circle-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid #ffffff;
    display: block;
    transition: transform 0.3s ease;
  }

  .story-circle-item:hover .story-circle-image {
    transform: scale(1.05);
  }

  .story-circle-title {
    font-size: 1.2rem;
    color: rgb(var(--color-foreground));
    text-align: center;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-family: var(--font-heading-family);
  }

{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="story-circles-wrapper" id="StoryCircles-{{ section.id }}">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="story-circle-item" {{ block.shopify_attributes }}>
          <div class="story-circle-image-container">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 200 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="story-circle-image"
                loading="lazy"
                width="200"
                height="200"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'story-circle-image placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <span class="story-circle-title">{{ block.settings.title | escape }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- if section.settings.auto_scroll -%}
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.querySelector('#StoryCircles-{{ section.id }}');
    if (!wrapper) return;
    
    let isHovered = false;

    // Pause scrolling when the user interacts with the circles
    wrapper.addEventListener('mouseenter', () => isHovered = true);
    wrapper.addEventListener('mouseleave', () => isHovered = false);
    wrapper.addEventListener('touchstart', () => isHovered = true, {passive: true});
    wrapper.addEventListener('touchend', () => isHovered = false, {passive: true});

    setInterval(() => {
      if (!isHovered) {
        const itemWidth = wrapper.querySelector('.story-circle-item')?.clientWidth || 100;
        const gap = parseInt(window.getComputedStyle(wrapper).gap) || 20;
        const scrollStep = itemWidth + gap;

        // If reached the end, snap back to the beginning smoothly
        if (wrapper.scrollLeft + wrapper.clientWidth >= wrapper.scrollWidth - 5) {
          wrapper.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          wrapper.scrollBy({ left: scrollStep, behavior: 'smooth' });
        }
      }
    }, {{ section.settings.scroll_interval | times: 1000 }});
  });
</script>
{%- endif -%}

{% schema %}
{
  "name": "Story Quick Links",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 24
    },
    {
      "type": "header",
      "content": "Auto Scroll Settings"
    },
    {
      "type": "checkbox",
      "id": "auto_scroll",
      "label": "Enable Auto Scroll",
      "default": true
    },
    {
      "type": "range",
      "id": "scroll_interval",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Scroll Interval",
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Quick Links",
      "blocks": [
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        }
      ]
    }
  ]
}
{% endschema %}
