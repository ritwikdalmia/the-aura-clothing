{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .testim-section {
    background: transparent;
    overflow: hidden;
    position: relative;
  }

  .testim-container {
    max-width: 160rem;
    margin: 0 auto;
    padding-left: 2.5rem;
    padding-right: 2.5rem;
  }

  @media screen and (min-width: 750px) {
    .testim-container {
      padding-left: 5rem;
      padding-right: 5rem;
    }
  }

  .testim-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .testim-title {
    font-size: 2.6rem;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    margin: 0;
    letter-spacing: 0.05em;
  }

  @media screen and (min-width: 750px) {
    .testim-title {
      font-size: 3.2rem;
    }
  }

  /* Carousel */
  .testim-carousel-wrapper {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .testim-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 1rem 0.5rem 3rem;
    margin: -1rem -0.5rem -3rem;
    scroll-behavior: smooth;
  }

  .testim-track::-webkit-scrollbar {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .testim-track {
      gap: 30px;
    }
  }

  /* Card */
  .testim-card {
    flex: 0 0 280px;
    scroll-snap-align: center;
    background: #ffffff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .testim-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.08);
  }

  @media screen and (min-width: 750px) {
    .testim-card {
      flex: 0 0 calc(33.333% - 20px);
    }
  }

  /* Image Box */
  .testim-image-box {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f0ece6;
  }

  .testim-image-box img,
  .testim-image-box svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .testim-card:hover .testim-image-box img {
    transform: scale(1.05);
  }

  .testim-placeholder-svg {
    padding: 20%;
    opacity: 0.5;
  }

  /* Content Box */
  .testim-content {
    padding: 2.5rem 2rem;
    text-align: center;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .testim-name-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: 1.5rem;
  }

  .testim-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #2c2c2c;
    margin: 0;
  }

  .testim-verified {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    background: #00B67A;
    border-radius: 50%;
  }

  .testim-verified svg {
    width: 10px;
    height: 10px;
    fill: #fff;
  }

  .testim-text {
    font-size: 1.35rem;
    line-height: 1.6;
    color: #4a4a4a;
    margin: 0;
  }

  /* Arrows */
  .testim-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: #e8e8e8;
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    z-index: 10;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .testim-arrow:hover {
    background: #d8d8d8;
    transform: translateY(-50%) scale(1.05);
  }

  .testim-arrow svg {
    width: 14px;
    height: 14px;
    fill: #333;
  }

  .testim-arrow--prev {
    left: -22px;
  }

  .testim-arrow--next {
    right: -22px;
  }

  @media screen and (min-width: 1300px) {
    .testim-arrow {
      display: flex;
    }
    .testim-arrow--prev { left: -60px; }
    .testim-arrow--next { right: -60px; }
  }

{%- endstyle -%}

<div class="testim-section color-{{ section.settings.color_scheme }} gradient">
  <div class="testim-container section-{{ section.id }}-padding">
    <div class="testim-header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <h2 class="testim-title">{{ section.settings.title | escape }}</h2>
    </div>

    <div class="testim-carousel-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <button class="testim-arrow testim-arrow--prev" aria-label="Previous" data-ts-prev>
        <svg viewBox="0 0 256 512"><path d="M31.7 239l136-136c9.4-9.4 24.6-9.4 33.9 0l22.6 22.6c9.4 9.4 9.4 24.6 0 33.9L127.9 256l96.4 96.4c9.4 9.4 9.4 24.6 0 33.9L201.7 409c-9.4 9.4-24.6 9.4-33.9 0l-136-136c-9.5-9.4-9.5-24.6-.1-34z"/></svg>
      </button>
      <button class="testim-arrow testim-arrow--next" aria-label="Next" data-ts-next>
        <svg viewBox="0 0 256 512"><path d="M224.3 273l-136 136c-9.4 9.4-24.6 9.4-33.9 0l-22.6-22.6c-9.4-9.4-9.4-24.6 0-33.9l96.4-96.4-96.4-96.4c-9.4-9.4-9.4-24.6 0-33.9L54.3 103c9.4-9.4 24.6-9.4 33.9 0l136 136c9.5 9.4 9.5 24.6 .1 34z"/></svg>
      </button>

      <div class="testim-track" data-ts-track>
        {%- for block in section.blocks -%}
          <div class="testim-card" {{ block.shopify_attributes }}>
            <div class="testim-image-box">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="600" height="600">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'testim-placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="testim-content">
              <div class="testim-name-row">
                <h3 class="testim-name">{{ block.settings.name }}</h3>
                {%- if block.settings.show_verified -%}
                  <span class="testim-verified" title="Verified Buyer">
                    <svg viewBox="0 0 512 512"><path d="M470.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L192 338.7 425.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg>
                  </span>
                {%- endif -%}
              </div>
              <p class="testim-text">{{ block.settings.review_text | newline_to_br }}</p>
            </div>
          </div>
        {%- endfor -%}

        {%- if section.blocks.size == 0 -%}
          {%- for i in (1..4) -%}
            <div class="testim-card">
              <div class="testim-image-box">
                {{ 'image' | placeholder_svg_tag: 'testim-placeholder-svg' }}
              </div>
              <div class="testim-content">
                <div class="testim-name-row">
                  <h3 class="testim-name">Customer Name</h3>
                  <span class="testim-verified">
                    <svg viewBox="0 0 512 512"><path d="M470.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L192 338.7 425.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg>
                  </span>
                </div>
                <p class="testim-text">This is such a pretty dress. Such soft material slipped like butter on me. I was initially worried... ✨</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.testim-carousel-wrapper').forEach(function (wrapper) {
      var track = wrapper.querySelector('[data-ts-track]');
      var prevBtn = wrapper.querySelector('[data-ts-prev]');
      var nextBtn = wrapper.querySelector('[data-ts-next]');
      if (!track) return;

      function scrollNext() {
        var card = track.querySelector('.testim-card');
        var cardWidth = card ? card.offsetWidth + 30 : 310;
        track.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }

      function scrollPrev() {
        var card = track.querySelector('.testim-card');
        var cardWidth = card ? card.offsetWidth + 30 : 310;
        track.scrollBy({ left: -cardWidth, behavior: 'smooth' });
      }

      if (prevBtn) prevBtn.addEventListener('click', scrollPrev);
      if (nextBtn) nextBtn.addEventListener('click', scrollNext);
    });
  });
</script>

{% schema %}
{
  "name": "Customer Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Image (Square recommended)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "Customer Name"
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show verified green checkmark",
          "default": true
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "I love this dress so much! ❤️"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Testimonials",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %}
