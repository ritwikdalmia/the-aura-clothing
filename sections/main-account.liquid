{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'aura-customer-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  <div class="account-header">
    <h1>Welcome back, {{ customer.first_name }}</h1>
    <p>Manage your orders, profile, and settings</p>
  </div>

  <div class="customer account-container">
    <!-- Sidebar Navigation -->
    <aside class="account-nav">
      <ul class="account-nav-list">
        <li class="account-nav-item is-active">
          <a href="{{ routes.account_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Dashboard
          </a>
        </li>
        <li class="account-nav-item">
          <a href="{{ routes.account_addresses_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            Addresses ({{ customer.addresses_count }})
          </a>
        </li>
        <li class="account-nav-item">
          <a href="{{ routes.account_logout_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Logout
          </a>
        </li>
      </ul>

      <div class="premium-form-card" style="margin-top: 3rem; padding: 2rem; text-align: left;">
        <h3 style="font-size: 1.4rem; margin-bottom: 1rem; text-transform: uppercase; color: var(--aura-gold);">Profile Details</h3>
        <p style="margin-bottom: 0.5rem; font-weight: 600;">{{ customer.name }}</p>
        <p style="margin-bottom: 1.5rem;">{{ customer.email }}</p>
        {{ customer.default_address | format_address }}
      </div>
    </aside>

    <!-- Main Content -->
    <main class="account-content">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
        <h2 style="font-size: 2.2rem; text-transform: uppercase; letter-spacing: 0.1em;">Order History</h2>
        {%- if customer.orders.size > 0 -%}
          <span class="status-badge status-badge--info">Total {{ customer.orders_count }} orders</span>
        {%- endif -%}
      </div>

      {% paginate customer.orders by 20 %}
        {%- if customer.orders.size > 0 -%}
          <div class="order-list">
            {%- for order in customer.orders -%}
              <div class="order-card">
                <div class="order-card__info">
                  <h3>Order {{ order.name }}</h3>
                  <p>{{ order.created_at | time_tag: format: 'date' }}</p>
                  <p style="margin-top: 1rem; font-weight: 600; color: var(--aura-gold);">{{ order.total_net_amount | money_with_currency }}</p>
                </div>
                
                <div style="text-align: right;">
                  <div style="margin-bottom: 1.5rem;">
                    <span class="status-badge {% if order.financial_status == 'paid' %}status-badge--success{% else %}status-badge--warning{% endif %}">
                      {{ order.financial_status_label }}
                    </span>
                    <span class="status-badge status-badge--info" style="margin-left: 0.5rem;">
                      {{ order.fulfillment_status_label }}
                    </span>
                  </div>
                  <a href="{{ order.customer_url }}" class="button button--secondary" style="font-size: 1.2rem; padding: 0.8rem 2rem;">
                    View Order Details
                  </a>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="premium-form-card" style="padding: 6rem 2rem;">
             <p style="color: #888;">{{ 'customer.orders.none' | t }}</p>
             <a href="{{ routes.all_products_collection_url }}" class="button" style="margin-top: 2rem;">
               Start Shopping
             </a>
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          {% render 'pagination', paginate: paginate %}
        {%- endif -%}
      {% endpaginate %}
    </main>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}

