{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'aura-customer-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  <div class="account-header">
    <h1>Welcome back, {{ customer.first_name }}</h1>
    <p>Manage your orders, profile, and settings</p>
  </div>

  <div class="customer account-container">
    <!-- Sidebar Navigation -->
    <aside class="account-nav">
      <ul class="account-nav-list">
        <li class="account-nav-item is-active">
          <a href="{{ routes.account_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Dashboard
          </a>
        </li>
        <li class="account-nav-item">
          <a href="{{ routes.account_addresses_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            Addresses ({{ customer.addresses_count }})
          </a>
        </li>
        <li class="account-nav-item">
          <a href="{{ routes.account_logout_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Logout
          </a>
        </li>
      </ul>

      <div class="premium-form-card" style="margin-top: 3rem; padding: 2.5rem; text-align: left; max-width: 100%;">
        <h3 style="font-size: 1.4rem; margin-top: 0; margin-bottom: 1.5rem; text-transform: uppercase; color: var(--aura-brand-gold); letter-spacing: 0.1em; font-weight: var(--aura-font-weight-semibold);">Profile Details</h3>
        <p style="margin-bottom: 0.5rem; font-weight: var(--aura-font-weight-semibold); color: var(--aura-brand-dark);">{{ customer.name }}</p>
        <p style="margin-bottom: 1.5rem; color: var(--aura-color-text-subtle);">{{ customer.email }}</p>
        <div style="font-size: 1.3rem; color: var(--aura-color-text-subtle); line-height: 1.6;">
          {{ customer.default_address | format_address }}
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="account-content">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem; flex-wrap: wrap; gap: 1.5rem;">
        <h2 style="font-size: 2.2rem; text-transform: uppercase; letter-spacing: 0.1em; margin: 0; color: var(--aura-brand-dark);">Order History</h2>
        {%- if customer.orders.size > 0 -%}
          <span class="status-badge status-badge--info">Total {{ customer.orders_count }} orders</span>
        {%- endif -%}
      </div>

      {% paginate customer.orders by 20 %}
        {%- if customer.orders.size > 0 -%}
          <div class="order-list">
            {%- for order in customer.orders -%}
              <div class="order-card" style="display: flex; gap: 2rem; align-items: center; justify-content: space-between; width: 100%;">
                <div style="display: flex; gap: 2rem; align-items: center; flex-grow: 1;">
                  <div class="order-card-image" style="width: 100px; height: 100px; border-radius: var(--aura-radius); overflow: hidden; background: var(--aura-brand-bg-warm); flex-shrink: 0; border: 1px solid rgba(168,139,106,0.12);">
                    {%- if order.line_items.first.image -%}
                      <img src="{{ order.line_items.first.image | image_url: width: 200 }}" alt="{{ order.line_items.first.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag }}
                    {%- endif -%}
                  </div>
                  <div class="order-card-details">
                    <h3 style="font-size: 1.8rem; margin: 0 0 0.5rem; text-transform: capitalize; font-weight: var(--aura-font-weight-semibold); color: var(--aura-brand-dark);">
                      {%- if order.fulfillment_status == 'fulfilled' -%}
                        Delivered
                      {%- elsif order.fulfillment_status == 'unfulfilled' -%}
                        Confirmed
                      {%- else -%}
                        {{ order.fulfillment_status_label | default: 'Confirmed' }}
                      {%- endif -%}
                    </h3>
                    <p style="margin: 0; font-size: 1.3rem; color: var(--aura-color-text-subtle);">
                      Order {{ order.name }} &bull; {{ order.total_net_amount | money_with_currency }} &bull; {{ order.created_at | time_tag: format: 'date' }}
                    </p>
                  </div>
                </div>
                <div class="order-card-actions" style="display: flex; gap: 1rem; align-items: center; flex-shrink: 0;">
                  <a href="{{ order.customer_url }}" class="button button--secondary">
                    View details
                  </a>
                  {%- if order.line_items.first.variant_id -%}
                    <form method="post" action="/cart/add" style="display: inline; margin: 0;">
                      <input type="hidden" name="id" value="{{ order.line_items.first.variant_id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="button button--primary">
                        Buy again
                      </button>
                    </form>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="premium-form-card" style="padding: 6rem 2rem;">
             <p style="color: var(--aura-color-text-subtle);">{{ 'customer.orders.none' | t }}</p>
             <a href="{{ routes.all_products_collection_url }}" class="button" style="margin-top: 2rem;">
               Start Shopping
             </a>
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          {% render 'pagination', paginate: paginate %}
        {%- endif -%}
      {% endpaginate %}
    </main>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}

